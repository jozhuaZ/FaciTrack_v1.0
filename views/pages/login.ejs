<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/login.css?v=<%= Date.now() %>">
<style>
  .login-main { background: var(--bg-light); }
  .login-back { display:inline-flex;align-items:center;gap:.375rem;font-size:.875rem;font-weight:500;color:var(--primary-blue);text-decoration:none;margin-bottom:.75rem;transition:opacity .15s; }
  .login-back:hover { opacity:.7; }
  .login-back svg { flex-shrink:0; }
  .login-role-hint { display:flex;gap:.5rem;flex-wrap:wrap;justify-content:center;margin-top:.75rem; }
  .role-chip { padding:3px 10px;border-radius:var(--radius-full);font-size:.6875rem;font-weight:600;letter-spacing:.3px; }
  .role-chip-i { background:rgba(10,61,98,.08);color:var(--primary-blue); }
  .role-chip-d { background:rgba(21,101,192,.1);color:#1565C0; }
  .role-chip-a { background:rgba(13,71,161,.1);color:#0D47A1; }
  .login-divider { text-align:center;font-size:.6875rem;color:var(--gray-400);margin:.5rem 0; }
</style>

<main class="login-main">
  <a href="/" class="back-btn login-back">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Back to Home
  </a>

  <div class="login-container">
    <div class="login-card">
      <div class="login-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>

      <div class="login-header">
        <h1 class="login-title">Login</h1>
        <p class="login-description">Sign in with your CSPC credentials</p>
      </div>

      <form action="/login" method="POST" class="login-form">
        <div class="form-group">
          <label for="email" class="form-label">CSPC Email Address <span class="required">*</span></label>
          <div class="input-wrapper">
            <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <input type="email" id="email" name="email" class="form-input <%= (error && error !== 'Please enter your password.') ? 'input-error' : '' %>" placeholder="yourname@cspc.edu.ph" required autofocus>
          </div>
          <% if (error && error !== 'Please enter your password.') { %>
            <span class="field-error">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <%= error %>
            </span>
          <% } %>
        </div>

        <div class="form-group">
          <label for="password" class="form-label">Password <span class="required">*</span></label>
          <div class="input-wrapper">
            <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            <input type="password" id="password" name="password" class="form-input <%= (error === 'Please enter your password.') ? 'input-error' : '' %>" placeholder="Enter your password" required>
          </div>
          <% if (error === 'Please enter your password.') { %>
            <span class="field-error">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <%= error %>
            </span>
          <% } %>
        </div>

        <button type="submit" class="btn-login">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
            <polyline points="10 17 15 12 10 7"/>
            <line x1="15" y1="12" x2="3" y2="12"/>
          </svg>
          Sign In
        </button>
      </form>

      <div class="login-footer">
        <div class="info-box">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
          </svg>
          <p>Demo — Instructor: <strong>instructor@cspc.edu.ph</strong> / instructor123 &nbsp;|&nbsp; Dean: <strong>dean@cspc.edu.ph</strong> / dean123 &nbsp;|&nbsp; Admin: <strong>admin@cspc.edu.ph</strong> / admin123</p>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/script') %>
