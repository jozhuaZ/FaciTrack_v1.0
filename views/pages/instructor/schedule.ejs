<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
/* ── Schedule page overrides ── */
.sched-info-banner { background:#eff6ff; border:1px solid #bfdbfe; border-radius:var(--radius-md); padding:.75rem 1rem; margin-bottom:1.25rem; display:flex; align-items:flex-start; gap:.625rem; }

/* Weekly 2-day display */
.sched-two-day-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1.25rem; }
@media(max-width:600px) { .sched-two-day-grid { grid-template-columns:1fr; } }

.sched-day-panel { background:#fff; border:1px solid var(--gray-200); border-radius:var(--radius-lg); overflow:hidden; box-shadow:var(--shadow-sm); }
.sched-day-panel-header { padding:.875rem 1.25rem; background:var(--gray-50); border-bottom:1px solid var(--gray-200); display:flex; align-items:center; justify-content:space-between; }
.sched-day-panel-name { font-size:.9375rem; font-weight:700; color:var(--primary-blue); }
.sched-day-panel-badge { font-size:.6875rem; font-weight:700; padding:3px 10px; border-radius:var(--radius-full); }
.sched-day-panel-badge.set { background:#f0fdf4; color:#16a34a; border:1px solid #bbf7d0; }
.sched-day-panel-badge.empty { background:var(--gray-100); color:var(--gray-400); border:1px solid var(--gray-200); }
.sched-day-panel-body { padding:1rem 1.25rem; }

/* Chopped slots display */
.chopped-slots-wrap { display:flex; flex-direction:column; gap:.5rem; margin-top:.75rem; }
.chopped-slot-item { display:flex; align-items:center; gap:.625rem; padding:.5rem .875rem; background:rgba(10,61,98,.04); border:1px solid rgba(10,61,98,.1); border-radius:var(--radius-md); font-size:.8125rem; }
.chopped-slot-num { width:22px; height:22px; border-radius:50%; background:var(--primary-blue); color:#fff; font-size:.6875rem; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.chopped-slot-time { font-weight:600; color:var(--gray-800); flex:1; }
.chopped-slot-avail { font-size:.6875rem; font-weight:700; padding:2px 8px; border-radius:var(--radius-full); background:#f0fdf4; color:#16a34a; border:1px solid #bbf7d0; }
.chopped-slot-avail.full { background:var(--gray-100); color:var(--gray-400); border-color:var(--gray-200); }

.no-day-set { text-align:center; padding:1.5rem; color:var(--gray-400); font-size:.8125rem; }
.no-day-set svg { display:block; margin:0 auto .5rem; opacity:.4; }

/* Modal time selects */
.time-range-row { display:grid; grid-template-columns:1fr auto 1fr; gap:.5rem; align-items:center; }
.time-range-sep { font-size:.875rem; color:var(--gray-500); font-weight:600; text-align:center; }
.modal-select-styled { padding:.6rem .875rem; border:1.5px solid var(--gray-300); border-radius:var(--radius-md); font-size:.875rem; font-family:var(--font-body); color:var(--gray-800); background:#fff; outline:none; width:100%; cursor:pointer; transition:border-color .2s; }
.modal-select-styled:focus { border-color:var(--primary-blue); box-shadow:0 0 0 3px rgba(10,61,98,.08); }

/* Capacity preview */
.capacity-preview { margin-top:.75rem; padding:.75rem 1rem; background:var(--gray-50); border:1px solid var(--gray-200); border-radius:var(--radius-md); }
.capacity-preview-title { font-size:.75rem; font-weight:700; color:var(--gray-600); margin-bottom:.5rem; text-transform:uppercase; letter-spacing:.4px; }
.capacity-preview-slots { display:flex; flex-wrap:wrap; gap:.375rem; }
.cap-slot-chip { padding:.3rem .75rem; background:#fff; border:1px solid var(--gray-200); border-radius:var(--radius-full); font-size:.75rem; color:var(--gray-700); font-weight:600; }

/* Edit modal */
.edit-slot-info { background:var(--gray-50); border:1px solid var(--gray-200); border-radius:var(--radius-md); padding:.75rem 1rem; margin-bottom:1rem; font-size:.8125rem; color:var(--gray-700); }
</style>

<div class="instructor-layout">
    <%- include('../../partials/instructor-sidebar', { activePage: 'schedule', pendingCount: pendingCount }) %>

    <main class="instructor-main">
        <div class="main-container">

            <div class="page-header">
                <div>
                    <h1 class="page-title">Consultation Schedule</h1>
                    <p class="page-subtitle">Set your two weekly consultation days and time slots</p>
                </div>
                <div class="header-actions">
                    <button class="btn-header-action primary" id="btnSetSchedule">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Set Schedule
                    </button>
                </div>
            </div>

            <!-- Two-Day Weekly Grid -->
            <div class="sched-two-day-grid" id="twoDayGrid">
                <!-- Rendered by JS from scheduleData -->
            </div>

            <!-- All Slots Table -->
            <div class="content-card">
                <div class="card-header">
                    <h3 class="card-title">All Consultation Slots</h3>
                    <button class="btn-header-action" id="btnExportSchedule">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        Export
                    </button>
                </div>
                <div class="card-body" style="padding:0;">
                    <table class="data-table" id="slotsTable">
                        <thead>
                            <tr>
                                <th>Day</th>
                                <th>Time Window</th>
                                <th>Slot</th>
                                <th>Booked</th>
                                <th>Capacity</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="slotsTableBody"></tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>
</div>

<!-- Set Schedule Modal -->
<div class="modal-overlay" id="setScheduleModal">
    <div class="modal-content" style="max-width:520px;">
        <div class="modal-header">
            <h3 class="modal-title" id="schedModalTitle">Set Consultation Schedule</h3>
            <button class="modal-close" id="closeSchedModal">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="modal-label">Day</label>
                <select class="modal-select-styled" id="schedDay">
                    <option value="Monday">Monday</option>
                    <option value="Tuesday">Tuesday</option>
                    <option value="Wednesday">Wednesday</option>
                    <option value="Thursday">Thursday</option>
                    <option value="Friday">Friday</option>
                    <option value="Saturday">Saturday</option>
                </select>
            </div>
            <div class="form-group">
                <label class="modal-label">Time Range</label>
                <div class="time-range-row">
                    <select class="modal-select-styled" id="schedTimeStart"></select>
                    <span class="time-range-sep">to</span>
                    <select class="modal-select-styled" id="schedTimeEnd"></select>
                </div>
            </div>
            <div class="form-group">
                <label class="modal-label">Max Capacity <span style="font-weight:400;color:var(--gray-500);">(students per session)</span></label>
                <select class="modal-select-styled" id="schedCapacity">
                    <option value="1">1 student</option>
                    <option value="2">2 students</option>
                    <option value="3" selected>3 students</option>
                    <option value="4">4 students</option>
                    <option value="5">5 students</option>
                    <option value="6">6 students</option>
                </select>
            </div>
            <!-- Live preview of chopped slots -->
            <div class="capacity-preview" id="capacityPreview">
                <p class="capacity-preview-title">Slot Preview</p>
                <div class="capacity-preview-slots" id="capacityPreviewSlots"></div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-modal btn-cancel" id="cancelSched">Cancel</button>
            <button class="btn-modal btn-confirm-green" id="confirmSched">Save Schedule</button>
        </div>
    </div>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
// ── Seed from server data ──
const serverSlots = <%- JSON.stringify(consultationSlots) %>;

// Version key — bump this to force-clear stale localStorage data
const SCHED_KEY = 'instructorSchedule_1_v2';

// Clear any old version keys
['instructorSchedule_1', 'instructorSchedule_1_v1'].forEach(k => localStorage.removeItem(k));

// scheduleData: load from localStorage if available, else use server data
const _saved = localStorage.getItem(SCHED_KEY);
let scheduleData = _saved ? JSON.parse(_saved) : serverSlots.map(s => ({
    day:         s.day,
    timeStart:   s.timeStart || (s.time ? s.time.split(' - ')[0].trim() : '2:00 PM'),
    timeEnd:     s.timeEnd   || (s.time ? s.time.split(' - ')[1].trim() : '3:00 PM'),
    maxCapacity: s.maxCapacity || 3,
    bookedCount: s.bookedCount || 0,
    status:      s.status || 'open'
}));

// ── Time options 8AM–5PM ──
const timeOptions = [
    '8:00 AM','8:30 AM','9:00 AM','9:30 AM','10:00 AM','10:30 AM',
    '11:00 AM','11:30 AM','12:00 PM','12:30 PM','1:00 PM','1:30 PM',
    '2:00 PM','2:30 PM','3:00 PM','3:30 PM','4:00 PM','4:30 PM','5:00 PM'
];

// Parse "2:00 PM" → minutes since midnight
function parseTime(str) {
    const [time, period] = str.split(' ');
    let [h, m] = time.split(':').map(Number);
    if (period === 'PM' && h !== 12) h += 12;
    if (period === 'AM' && h === 12) h = 0;
    return h * 60 + m;
}

// Format minutes → "2:00 PM"
function formatTime(mins) {
    let h = Math.floor(mins / 60);
    const m = mins % 60;
    const period = h >= 12 ? 'PM' : 'AM';
    if (h > 12) h -= 12;
    if (h === 0) h = 12;
    return `${h}:${m.toString().padStart(2,'0')} ${period}`;
}

// Chop time window into N equal slots
function chopSlots(timeStart, timeEnd, capacity) {
    const startMins = parseTime(timeStart);
    const endMins = parseTime(timeEnd);
    const totalMins = endMins - startMins;
    if (totalMins <= 0) return [];
    const slotMins = Math.floor(totalMins / capacity);
    const slots = [];
    for (let i = 0; i < capacity; i++) {
        const s = startMins + i * slotMins;
        const e = s + slotMins;
        slots.push(`${formatTime(s)} – ${formatTime(e)}`);
    }
    return slots;
}

// ── Populate start dropdown (8AM–4:30PM so end can be at least 8:30AM) ──
function populateTimeStart(selectEl, selectedVal) {
    selectEl.innerHTML = '';
    timeOptions.slice(0, -1).forEach(t => {   // exclude 5:00 PM as a start
        const opt = document.createElement('option');
        opt.value = t;
        opt.textContent = t;
        if (t === selectedVal) opt.selected = true;
        selectEl.appendChild(opt);
    });
}

// ── Populate end dropdown with only times AFTER the selected start ──
function populateTimeEnd(selectEl, selectedVal) {
    const startMins = parseTime(document.getElementById('schedTimeStart').value);
    selectEl.innerHTML = '';
    timeOptions.filter(t => parseTime(t) > startMins).forEach(t => {
        const opt = document.createElement('option');
        opt.value = t;
        opt.textContent = t;
        if (t === selectedVal) opt.selected = true;
        selectEl.appendChild(opt);
    });
    // If nothing selected, pick first option
    if (!selectEl.value && selectEl.options.length > 0) {
        selectEl.selectedIndex = 0;
    }
}

function onStartChange() {
    const endEl = document.getElementById('schedTimeEnd');
    const currentEnd = endEl.value;
    populateTimeEnd(endEl, currentEnd);
    updatePreview();
}

function updatePreview() {
    const start = document.getElementById('schedTimeStart').value;
    const end = document.getElementById('schedTimeEnd').value;
    const cap = parseInt(document.getElementById('schedCapacity').value);
    if (!start || !end) return;
    const slots = chopSlots(start, end, cap);
    const container = document.getElementById('capacityPreviewSlots');
    container.innerHTML = slots.length
        ? slots.map(s => `<span class="cap-slot-chip">${s}</span>`).join('')
        : '<span style="font-size:.75rem;color:var(--gray-400);">Select a valid time range.</span>';
}

// ── Render two-day panels ──
function renderTwoDayGrid() {
    const grid = document.getElementById('twoDayGrid');
    grid.innerHTML = '';
    for (let i = 0; i < 2; i++) {
        const slot = scheduleData[i];
        const panel = document.createElement('div');
        panel.className = 'sched-day-panel';
        if (slot) {
            const choppedSlots = chopSlots(slot.timeStart, slot.timeEnd, slot.maxCapacity);
            panel.innerHTML = `
                <div class="sched-day-panel-header">
                    <span class="sched-day-panel-name">${slot.day}</span>
                    <div style="display:flex;align-items:center;gap:.5rem;">
                        <span class="sched-day-panel-badge set">Active</span>
                        <button class="btn-table-action edit" onclick="openEditModal(${i})" style="font-size:.75rem;padding:.3rem .625rem;">Edit</button>
                        <button class="btn-table-action delete" onclick="removeSlot(${i})" style="font-size:.75rem;padding:.3rem .625rem;">Remove</button>
                    </div>
                </div>
                <div class="sched-day-panel-body">
                    <div style="font-size:.8125rem;color:var(--gray-600);margin-bottom:.25rem;">
                        <strong>${slot.timeStart} – ${slot.timeEnd}</strong> &nbsp;·&nbsp; ${slot.maxCapacity} slots/session
                    </div>
                    <div class="chopped-slots-wrap">
                        ${choppedSlots.map((s, idx) => `
                            <div class="chopped-slot-item">
                                <span class="chopped-slot-num">${idx + 1}</span>
                                <span class="chopped-slot-time">${s}</span>
                                <span class="chopped-slot-avail ${slot.status === 'full' ? 'full' : ''}">
                                    ${slot.status === 'full' ? 'Full' : 'Available'}
                                </span>
                            </div>`).join('')}
                    </div>
                </div>`;
        } else {
            panel.innerHTML = `
                <div class="sched-day-panel-header">
                    <span class="sched-day-panel-name">Day ${i + 1}</span>
                    <span class="sched-day-panel-badge empty">Not Set</span>
                </div>
                <div class="sched-day-panel-body">
                    <div class="no-day-set">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        No consultation day set
                    </div>
                    <button class="btn-header-action primary" style="width:100%;justify-content:center;margin-top:.5rem;" onclick="openAddModal()">+ Set Day ${i + 1}</button>
                </div>`;
        }
        grid.appendChild(panel);
    }
    renderTable();
}

// ── Render table ──
function renderTable() {
    const tbody = document.getElementById('slotsTableBody');
    tbody.innerHTML = '';
    if (scheduleData.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--gray-400);padding:2rem;">No consultation slots configured.</td></tr>';
        return;
    }
    scheduleData.forEach((slot, i) => {
        const choppedSlots = chopSlots(slot.timeStart, slot.timeEnd, slot.maxCapacity);
        choppedSlots.forEach((cs, idx) => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${idx === 0 ? `<strong>${slot.day}</strong>` : ''}</td>
                <td>${idx === 0 ? `${slot.timeStart} – ${slot.timeEnd}` : ''}</td>
                <td>Slot ${idx + 1}: ${cs}</td>
                <td>${idx === 0 ? slot.bookedCount : '—'}</td>
                <td>${idx === 0 ? slot.maxCapacity : '—'}</td>
                <td>${idx === 0 ? `<span class="table-badge ${slot.status}">${slot.status === 'open' ? 'Available' : 'Full'}</span>` : ''}</td>
                <td>${idx === 0 ? `<button class="btn-table-action edit" onclick="openEditModal(${i})">Edit</button><button class="btn-table-action delete" onclick="removeSlot(${i})">Remove</button>` : ''}</td>`;
            tbody.appendChild(tr);
        });
    });
}

// ── Modal helpers ──
let editingIndex = -1;

function openAddModal() {
    if (scheduleData.length >= 2) { showToast('error', 'Limit Reached', 'You can only set 2 consultation days per week.'); return; }
    editingIndex = -1;
    document.getElementById('schedModalTitle').textContent = 'Add Consultation Day';
    populateTimeStart(document.getElementById('schedTimeStart'), '2:00 PM');
    populateTimeEnd(document.getElementById('schedTimeEnd'), '3:00 PM');
    document.getElementById('schedCapacity').value = '3';
    updatePreview();
    document.getElementById('setScheduleModal').classList.add('show');
}

function openEditModal(idx) {
    editingIndex = idx;
    const slot = scheduleData[idx];
    document.getElementById('schedModalTitle').textContent = 'Edit Consultation Day';
    document.getElementById('schedDay').value = slot.day;
    populateTimeStart(document.getElementById('schedTimeStart'), slot.timeStart);
    populateTimeEnd(document.getElementById('schedTimeEnd'), slot.timeEnd);
    document.getElementById('schedCapacity').value = slot.maxCapacity;
    updatePreview();
    document.getElementById('setScheduleModal').classList.add('show');
}

function removeSlot(idx) {
    scheduleData.splice(idx, 1);
    showToast('success', 'Removed', 'Consultation day removed.');
    saveSchedule();
}

document.getElementById('btnSetSchedule').addEventListener('click', openAddModal);
document.getElementById('closeSchedModal').addEventListener('click', () => document.getElementById('setScheduleModal').classList.remove('show'));
document.getElementById('cancelSched').addEventListener('click', () => document.getElementById('setScheduleModal').classList.remove('show'));

document.getElementById('schedTimeStart').addEventListener('change', onStartChange);
document.getElementById('schedCapacity').addEventListener('change', updatePreview);

document.getElementById('confirmSched').addEventListener('click', () => {
    const day = document.getElementById('schedDay').value;
    const timeStart = document.getElementById('schedTimeStart').value;
    const timeEnd = document.getElementById('schedTimeEnd').value;
    const maxCapacity = parseInt(document.getElementById('schedCapacity').value);

    if (!timeStart || !timeEnd) { showToast('error', 'Required', 'Please select a time range.'); return; }
    if (parseTime(timeStart) >= parseTime(timeEnd)) { showToast('error', 'Invalid Range', 'End time must be after start time.'); return; }

    // Check duplicate day
    const dupIdx = scheduleData.findIndex((s, i) => s.day === day && i !== editingIndex);
    if (dupIdx !== -1) { showToast('error', 'Duplicate Day', `${day} is already set. Please choose a different day.`); return; }

    const newSlot = { day, timeStart, timeEnd, maxCapacity, bookedCount: editingIndex >= 0 ? scheduleData[editingIndex].bookedCount : 0, status: 'open' };
    if (editingIndex >= 0) {
        scheduleData[editingIndex] = newSlot;
        showToast('success', 'Updated', `${day} schedule updated.`);
    } else {
        scheduleData.push(newSlot);
        showToast('success', 'Added', `${day} ${timeStart} – ${timeEnd} added.`);
    }
    document.getElementById('setScheduleModal').classList.remove('show');
    saveSchedule();
});

function saveSchedule() {
    localStorage.setItem(SCHED_KEY, JSON.stringify(scheduleData));
    renderTwoDayGrid();
}

document.getElementById('btnExportSchedule').addEventListener('click', () => showToast('success', 'Exported', 'Schedule exported successfully.'));

function showToast(type, title, message) {
    const c = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.innerHTML = `<div class="toast-content"><p class="toast-title">${title}</p><p class="toast-message">${message}</p></div>`;
    c.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 4000);
}

// Init
populateTimeStart(document.getElementById('schedTimeStart'), '2:00 PM');
populateTimeEnd(document.getElementById('schedTimeEnd'), '3:00 PM');
updatePreview();
renderTwoDayGrid();
</script>
