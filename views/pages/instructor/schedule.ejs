<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
    html, body { overflow: hidden !important; height: 100vh !important; }
    body { display: flex; flex-direction: column; }
    main { flex: 1; min-height: 0; display: flex; flex-direction: column; }
</style>

<div class="instructor-layout">
    <%- include('../../partials/instructor-sidebar', { activePage: 'schedule', pendingCount: pendingCount }) %>

    <main class="instructor-main">
        <div class="main-container">

            <div class="page-header">
                <div>
                    <h1 class="page-title">Consultation Schedule</h1>
                    <p class="page-subtitle">Manage your weekly consultation hours and availability</p>
                </div>
                <div class="header-actions">
                    <button class="btn-header-action primary" id="btnAddSlot">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Add Slot
                    </button>
                </div>
            </div>

            <!-- Weekly Schedule Grid -->
            <div class="schedule-week-grid">
                <% const days = ['Monday','Tuesday','Wednesday','Thursday','Friday']; %>
                <% days.forEach(day => { %>
                <div class="schedule-day-card">
                    <div class="schedule-day-header">
                        <h3 class="schedule-day-name"><%= day %></h3>
                        <button class="btn-add-day-slot" data-day="<%= day %>">+ Add</button>
                    </div>
                    <div class="schedule-day-slots">
                        <% const daySlots = consultationSlots.filter(s => s.day === day); %>
                        <% if (daySlots.length === 0) { %>
                        <div class="no-slot-text">No slots set</div>
                        <% } else { %>
                        <% daySlots.forEach(slot => { %>
                        <div class="schedule-slot-item <%= slot.status %>">
                            <div class="slot-time-text">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                <%= slot.time %>
                            </div>
                            <div class="slot-meta">
                                <span class="slot-capacity"><%= slot.bookedCount %>/<%= slot.maxCapacity %> booked</span>
                                <span class="slot-status-dot <%= slot.status %>"></span>
                            </div>
                        </div>
                        <% }); %>
                        <% } %>
                    </div>
                </div>
                <% }); %>
            </div>

            <!-- All Slots Table -->
            <div class="content-card">
                <div class="card-header">
                    <h3 class="card-title">All Consultation Slots</h3>
                    <button class="btn-header-action" id="btnExportSchedule">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        Export
                    </button>
                </div>
                <div class="card-body" style="padding:0;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Day</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Booked</th>
                                <th>Capacity</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% consultationSlots.forEach(slot => { %>
                            <tr>
                                <td><strong><%= slot.day %></strong></td>
                                <td><%= slot.date %></td>
                                <td><%= slot.time %></td>
                                <td><%= slot.bookedCount %></td>
                                <td><%= slot.maxCapacity %></td>
                                <td><span class="table-badge <%= slot.status %>"><%= slot.status === 'open' ? 'Available' : 'Full' %></span></td>
                                <td>
                                    <button class="btn-table-action edit">Edit</button>
                                    <button class="btn-table-action delete">Remove</button>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>
</div>

<!-- Add Slot Modal -->
<div class="modal-overlay" id="addSlotModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">Add Consultation Slot</h3>
            <button class="modal-close" id="closeSlotModal">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="modal-label">Day</label>
                <select class="modal-select" id="slotDay">
                    <option>Monday</option><option>Tuesday</option><option>Wednesday</option>
                    <option>Thursday</option><option>Friday</option>
                </select>
            </div>
            <div class="form-group">
                <label class="modal-label">Time Range</label>
                <input type="text" class="modal-input" id="slotTime" placeholder="e.g. 2:00 PM - 4:00 PM">
            </div>
            <div class="form-group">
                <label class="modal-label">Max Capacity</label>
                <input type="number" class="modal-input" id="slotCapacity" value="3" min="1" max="10">
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-modal btn-cancel" id="cancelSlot">Cancel</button>
            <button class="btn-modal btn-confirm-green" id="confirmSlot">Add Slot</button>
        </div>
    </div>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
function showToast(type, title, message) {
    const c = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.innerHTML = `<div class="toast-content"><p class="toast-title">${title}</p><p class="toast-message">${message}</p></div>`;
    c.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 4000);
}

document.getElementById('btnAddSlot').addEventListener('click', () => document.getElementById('addSlotModal').classList.add('show'));
document.getElementById('closeSlotModal').addEventListener('click', () => document.getElementById('addSlotModal').classList.remove('show'));
document.getElementById('cancelSlot').addEventListener('click', () => document.getElementById('addSlotModal').classList.remove('show'));
document.getElementById('confirmSlot').addEventListener('click', () => {
    const day = document.getElementById('slotDay').value;
    const time = document.getElementById('slotTime').value.trim();
    if (!time) { showToast('error', 'Required', 'Please enter a time range.'); return; }
    showToast('success', 'Slot Added', `${day} ${time} has been added.`);
    document.getElementById('addSlotModal').classList.remove('show');
});

document.querySelectorAll('.btn-add-day-slot').forEach(btn => {
    btn.addEventListener('click', function() {
        document.getElementById('slotDay').value = this.dataset.day;
        document.getElementById('addSlotModal').classList.add('show');
    });
});

document.getElementById('btnExportSchedule').addEventListener('click', () => showToast('success', 'Exported', 'Schedule exported successfully.'));

document.querySelectorAll('.btn-table-action.delete').forEach(btn => {
    btn.addEventListener('click', function() {
        this.closest('tr').style.opacity = '0.4';
        showToast('success', 'Removed', 'Slot has been removed.');
    });
});
</script>
