<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
.period-filter-bar{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
.period-pill{padding:.5rem 1.125rem;border:1.5px solid var(--gray-200);border-radius:999px;background:#fff;font-size:.8125rem;font-weight:600;color:var(--gray-600);cursor:pointer;transition:all .2s;font-family:var(--font-body)}
.period-pill:hover{border-color:var(--primary-blue);color:var(--primary-blue)}
.period-pill.active{background:var(--primary-blue);border-color:var(--primary-blue);color:#fff}
#customDateInput{display:none;padding:.45rem .875rem;border:1.5px solid var(--gray-200);border-radius:999px;font-size:.8125rem;font-family:var(--font-body);color:var(--gray-800);background:#fff;outline:none}
.analytics-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
@media(max-width:900px){.analytics-grid{grid-template-columns:1fr}}
</style>
<div class="instructor-layout">
  <%- include('../../partials/instructor-sidebar', { activePage: 'reports', pendingCount: pendingCount }) %>
  <main class="instructor-main">
    <div class="main-container">
      <div class="page-header">
        <div>
          <h1 class="page-title">Reports</h1>
          <p class="page-subtitle">Consultation workload summary</p>
        </div>
        <div class="header-actions">
          <button class="btn-header-action" id="btnDownload">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download
          </button>
          <button class="btn-header-action primary" id="btnPrint">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            Print
          </button>
        </div>
      </div>
      <div class="content-card">
        <div class="card-body" style="padding:.875rem 1.25rem">
          <div class="period-filter-bar">
            <button class="period-pill active" data-period="week">This Week</button>
            <button class="period-pill" data-period="month">This Month</button>
            <button class="period-pill" data-period="all">All Time</button>
            <button class="period-pill" data-period="custom">Custom Date</button>
            <input type="date" id="customDateInput" aria-label="Custom date">
          </div>
        </div>
      </div>
      <div class="stats-overview">
        <div class="stat-card-large presence">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">Total Appointments</p>
            <h2 class="stat-card-value" id="statTotal"><%= appointments.length %></h2>
            <p class="stat-card-sublabel" id="statTotalSub">All records</p>
          </div>
        </div>
        <div class="stat-card-large confirmed">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">Confirmed</p>
            <h2 class="stat-card-value" id="statConfirmed"><%= appointments.filter(function(a){return a.status==='confirmed';}).length %></h2>
            <p class="stat-card-sublabel">Completed</p>
          </div>
        </div>
        <div class="stat-card-large pending">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">Declined</p>
            <h2 class="stat-card-value" id="statDeclined"><%= appointments.filter(function(a){return a.status==='declined';}).length %></h2>
            <p class="stat-card-sublabel">Rejected</p>
          </div>
        </div>
        <div class="stat-card-large workload">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">Avg Duration</p>
            <h2 class="stat-card-value"><%= workloadStats.thisWeek.averageDuration %></h2>
            <p class="stat-card-sublabel">Per consultation</p>
          </div>
        </div>
      </div>
      <div class="analytics-grid">
        <div class="content-card">
          <div class="card-header">
            <h3 class="card-title">Appointment Activity</h3>
            <span style="font-size:.75rem;color:var(--gray-400)">Mon-Fri this week</span>
          </div>
          <div class="card-body">
            <div class="bar-chart">
              <%
                var trendVals = workloadStats.trends.map(function(t){return t.consultations;});
                var maxTrend = 1;
                for(var ti=0;ti<trendVals.length;ti++){ if(trendVals[ti]>maxTrend) maxTrend=trendVals[ti]; }
              %>
              <% for(var ti2=0;ti2<workloadStats.trends.length;ti2++){ %>
              <%   var tr = workloadStats.trends[ti2]; %>
              <%   var pct = Math.round((tr.consultations/maxTrend)*100); %>
              <div class="bar-chart-item">
                <div class="bar-chart-bar-wrap">
                  <div class="bar-chart-bar" style="height:<%= pct %>%" title="<%= tr.consultations %> consultations">
                    <% if(pct>=30){ %><span class="bar-value"><%= tr.consultations %></span><% } %>
                  </div>
                </div>
                <span class="bar-label"><%= tr.day %></span>
              </div>
              <% } %>
            </div>
            <p class="chart-legend">Consultations per day (this week)</p>
          </div>
        </div>
        <div class="content-card">
          <div class="card-header">
            <h3 class="card-title">Appointment Breakdown</h3>
            <span id="breakdownPeriodLabel" style="font-size:.75rem;color:var(--gray-400)">This Week</span>
          </div>
          <div class="card-body">
            <%
              var bdTot  = appointments.length || 1;
              var bdConf = appointments.filter(function(a){return a.status==='confirmed';}).length;
              var bdDecl = appointments.filter(function(a){return a.status==='declined';}).length;
              var bdPend = appointments.filter(function(a){return a.status==='pending';}).length;
            %>
            <div class="workload-breakdown" id="breakdownList">
              <div class="breakdown-row">
                <span class="breakdown-label"><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#16a34a;margin-right:.4rem;vertical-align:middle"></span>Confirmed</span>
                <div class="breakdown-bar-wrap"><div class="breakdown-bar confirmed" style="width:<%= Math.round(bdConf/bdTot*100) %>%"></div></div>
                <span class="breakdown-value"><%= bdConf %></span>
              </div>
              <div class="breakdown-row">
                <span class="breakdown-label"><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#dc2626;margin-right:.4rem;vertical-align:middle"></span>Declined</span>
                <div class="breakdown-bar-wrap"><div class="breakdown-bar" style="width:<%= Math.round(bdDecl/bdTot*100) %>%;background:linear-gradient(90deg,#dc2626,#ef4444)"></div></div>
                <span class="breakdown-value"><%= bdDecl %></span>
              </div>
              <div class="breakdown-row">
                <span class="breakdown-label"><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#ea580c;margin-right:.4rem;vertical-align:middle"></span>Pending</span>
                <div class="breakdown-bar-wrap"><div class="breakdown-bar" style="width:<%= Math.round(bdPend/bdTot*100) %>%;background:linear-gradient(90deg,#ea580c,#fb923c)"></div></div>
                <span class="breakdown-value"><%= bdPend %></span>
              </div>
            </div>
            <div style="display:flex;gap:.75rem;margin-top:1.5rem;padding-top:1rem;border-top:1px solid var(--gray-100)">
              <div style="flex:1;text-align:center;padding:.625rem;background:rgba(22,163,74,.06);border-radius:8px">
                <p style="font-size:1.125rem;font-weight:800;color:#15803d;margin:0"><%= workloadStats.thisWeek.consultationsCompleted %></p>
                <p style="font-size:.65rem;color:var(--gray-500);text-transform:uppercase;letter-spacing:.04em;margin:2px 0 0">This Week</p>
              </div>
              <div style="flex:1;text-align:center;padding:.625rem;background:rgba(10,61,98,.06);border-radius:8px">
                <p style="font-size:1.125rem;font-weight:800;color:var(--primary-blue);margin:0"><%= workloadStats.thisMonth.consultationsCompleted %></p>
                <p style="font-size:.65rem;color:var(--gray-500);text-transform:uppercase;letter-spacing:.04em;margin:2px 0 0">This Month</p>
              </div>
              <div style="flex:1;text-align:center;padding:.625rem;background:rgba(124,58,237,.06);border-radius:8px">
                <p style="font-size:1.125rem;font-weight:800;color:#7c3aed;margin:0"><%= workloadStats.thisWeek.hoursLogged %>h</p>
                <p style="font-size:.65rem;color:var(--gray-500);text-transform:uppercase;letter-spacing:.04em;margin:2px 0 0">Hrs/Week</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="content-card">
        <div class="card-header">
          <h3 class="card-title">Appointments</h3>
          <span id="tablePeriodLabel" style="font-size:.8125rem;color:var(--gray-500);font-weight:600">This Week</span>
        </div>
        <div class="card-body" style="padding:0">
          <div style="overflow-x:auto">
            <table class="data-table">
              <thead><tr><th>Student</th><th>Date</th><th>Time</th><th>Topic</th><th>Status</th><th>Duration</th></tr></thead>
              <tbody id="appointmentsBody">
                <% appointments.forEach(function(apt){ %>
                <tr class="apt-data-row" data-date="<%= apt.date %>" data-status="<%= apt.status %>">
                  <td>
                    <div style="display:flex;align-items:center;gap:.625rem">
                      <div class="apt-avatar-xs" style="font-size:.6875rem"><%= apt.studentName.split(' ').map(function(n){return n[0];}).join('').slice(0,2).toUpperCase() %></div>
                      <div>
                        <p style="font-weight:600;font-size:.875rem;color:var(--gray-900);margin:0"><%= apt.studentName %></p>
                        <p style="font-size:.6875rem;color:var(--gray-400);margin:0"><%= apt.studentId %></p>
                      </div>
                    </div>
                  </td>
                  <td style="white-space:nowrap"><%= apt.date %></td>
                  <td style="white-space:nowrap"><%= apt.time %></td>
                  <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= apt.topic %>"><%= apt.topic %></td>
                  <td><span class="table-badge <%= apt.status %>"><%= apt.status.charAt(0).toUpperCase()+apt.status.slice(1) %></span></td>
                  <td><%= apt.duration %></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <div class="pagination-bar">
            <span class="page-info" id="pageInfo">-</span>
            <div class="pagination-controls">
              <button class="btn-page" id="btnPrev" disabled>Prev</button>
              <button class="btn-page" id="btnNext" disabled>Next</button>
            </div>
          </div>
        </div>
      </div>
      <div class="content-card">
        <div class="card-header">
          <h3 class="card-title">CSPC Institutional Report Preview</h3>
          <span id="previewPeriodLabel" style="font-size:.8125rem;color:var(--gray-500);font-weight:600">This Week</span>
        </div>
        <div class="card-body">
          <div class="report-preview">
            <div class="report-header-block" style="display:flex;align-items:center;gap:1rem;text-align:left;padding:1.25rem 1.5rem">
              <img src="/images/CSPC-logo.png" alt="CSPC" style="width:52px;height:52px;object-fit:contain;flex-shrink:0" onerror="this.style.display='none'">
              <div>
                <p class="report-institution">Camarines Sur Polytechnic Colleges</p>
                <p class="report-college">College of Computer Studies</p>
                <h4 class="report-title-block">Faculty Consultation Workload Report</h4>
                <p class="report-period">Faculty: <strong><%= instructor.name %></strong> &middot; Period: <span id="previewPeriodText">This Week</span></p>
              </div>
            </div>
            <div style="padding:1.25rem 1.5rem">
              <table class="data-table">
                <thead><tr><th>Faculty Name</th><th>Room</th><th>Total Hours</th><th>Consultations</th><th>Avg Duration</th><th>Pending</th></tr></thead>
                <tbody>
                  <tr>
                    <td><strong><%= instructor.name %></strong></td>
                    <td><%= instructor.officeRoom || '-' %></td>
                    <td id="previewHours"><%= workloadStats.thisWeek.hoursLogged %>h</td>
                    <td id="previewConsult"><%= workloadStats.thisWeek.consultationsCompleted %></td>
                    <td><%= workloadStats.thisWeek.averageDuration %></td>
                    <td><span class="table-badge pending"><%= pendingCount %></span></td>
                  </tr>
                </tbody>
              </table>
              <p style="font-size:.75rem;color:var(--gray-400);margin-top:1rem;font-style:italic">Auto-generated by FaciTrack. Verify with department records before official submission.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
(function(){
  var ALL=<%- JSON.stringify(appointments) %>;
  var WS=<%- JSON.stringify(workloadStats) %>;
  var period='week',customDate='',page=1,PAGE=5;
  var pills=document.querySelectorAll('.period-pill');
  var custInput=document.getElementById('customDateInput');
  var tbody=document.getElementById('appointmentsBody');
  var pageInfo=document.getElementById('pageInfo');
  var btnPrev=document.getElementById('btnPrev');
  var btnNext=document.getElementById('btnNext');
  function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
  function weekRange(){var d=new Date(),s=new Date(d);s.setDate(d.getDate()-d.getDay());var e=new Date(s);e.setDate(s.getDate()+6);return{s:s,e:e};}
  function monthRange(){var d=new Date();return{s:new Date(d.getFullYear(),d.getMonth(),1),e:new Date(d.getFullYear(),d.getMonth()+1,0)};}
  function filter(){
    if(period==='all') return ALL;
    if(period==='week'){var r=weekRange();return ALL.filter(function(a){var d=new Date(a.date);return d>=r.s&&d<=r.e;});}
    if(period==='month'){var r2=monthRange();return ALL.filter(function(a){var d=new Date(a.date);return d>=r2.s&&d<=r2.e;});}
    if(period==='custom'&&customDate){var t=new Date(customDate);return ALL.filter(function(a){return new Date(a.date).toDateString()===t.toDateString();});}
    return ALL;
  }
  function lbl(){return{week:'This Week',month:'This Month',all:'All Time',custom:customDate||'Custom Date'}[period]||'';}
  function renderTable(rows){
    var total=rows.length,pages=Math.max(1,Math.ceil(total/PAGE));
    if(page>pages) page=pages;
    var s=(page-1)*PAGE,slice=rows.slice(s,s+PAGE);
    tbody.innerHTML='';
    if(!slice.length){
      tbody.innerHTML='<tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--gray-400)">No appointments found for this period.</td></tr>';
    } else {
      slice.forEach(function(a){
        var init=a.studentName.split(' ').map(function(n){return n[0];}).join('').slice(0,2).toUpperCase();
        var sc=a.status.charAt(0).toUpperCase()+a.status.slice(1);
        var tr=document.createElement('tr');
        tr.innerHTML='<td><div style="display:flex;align-items:center;gap:.625rem"><div class="apt-avatar-xs" style="font-size:.6875rem">'+init+'</div><div><p style="font-weight:600;font-size:.875rem;color:var(--gray-900);margin:0">'+esc(a.studentName)+'</p><p style="font-size:.6875rem;color:var(--gray-400);margin:0">'+esc(a.studentId)+'</p></div></div></td><td style="white-space:nowrap">'+esc(a.date)+'</td><td style="white-space:nowrap">'+esc(a.time)+'</td><td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+esc(a.topic)+'</td><td><span class="table-badge '+a.status+'">'+sc+'</span></td><td>'+esc(a.duration)+'</td>';
        tbody.appendChild(tr);
      });
    }
    pageInfo.textContent=total?('Showing '+(s+1)+'-'+Math.min(s+PAGE,total)+' of '+total):'No results';
    btnPrev.disabled=page<=1; btnNext.disabled=page>=pages;
  }
  function updateStats(rows){
    var conf=rows.filter(function(a){return a.status==='confirmed';}).length;
    var decl=rows.filter(function(a){return a.status==='declined';}).length;
    var pend=rows.filter(function(a){return a.status==='pending';}).length;
    var tot=rows.length||1;
    document.getElementById('statTotal').textContent=rows.length;
    document.getElementById('statTotalSub').textContent=rows.length===ALL.length?'All records':'In period';
    document.getElementById('statConfirmed').textContent=conf;
    document.getElementById('statDeclined').textContent=decl;
    var brows=document.querySelectorAll('#breakdownList .breakdown-row');
    if(brows.length>=3){
      [[0,conf],[1,decl],[2,pend]].forEach(function(pair){
        brows[pair[0]].querySelector('.breakdown-bar').style.width=Math.round(pair[1]/tot*100)+'%';
        brows[pair[0]].querySelector('.breakdown-value').textContent=pair[1];
      });
    }
  }
  function apply(){
    var l=lbl(),rows=filter();
    ['tablePeriodLabel','breakdownPeriodLabel','previewPeriodLabel'].forEach(function(id){var el=document.getElementById(id);if(el)el.textContent=l;});
    var pt=document.getElementById('previewPeriodText');if(pt)pt.textContent=l;
    var isWeek=period==='week'||period==='custom';
    var ph=document.getElementById('previewHours');if(ph)ph.textContent=(isWeek?WS.thisWeek.hoursLogged:WS.thisMonth.hoursLogged)+'h';
    var pc=document.getElementById('previewConsult');if(pc)pc.textContent=isWeek?WS.thisWeek.consultationsCompleted:WS.thisMonth.consultationsCompleted;
    updateStats(rows);
    renderTable(rows);
  }
  pills.forEach(function(p){
    p.addEventListener('click',function(){
      pills.forEach(function(x){x.classList.remove('active');});
      p.classList.add('active');
      period=p.dataset.period; page=1;
      custInput.style.display=period==='custom'?'inline-block':'none';
      if(period!=='custom'){customDate='';apply();}
    });
  });
  custInput.addEventListener('change',function(){customDate=this.value;page=1;apply();});
  btnPrev.addEventListener('click',function(){if(page>1){page--;renderTable(filter());}});
  btnNext.addEventListener('click',function(){var r=filter(),pages=Math.ceil(r.length/PAGE);if(page<pages){page++;renderTable(r);}});
  document.getElementById('btnDownload').addEventListener('click',function(){
    var c=document.getElementById('toastContainer'),t=document.createElement('div');
    t.className='toast success';t.innerHTML='<div class="toast-content"><p class="toast-title">Preparing</p><p class="toast-message">CSPC workload report is being prepared.</p></div>';
    c.appendChild(t);setTimeout(function(){t.style.opacity='0';setTimeout(function(){t.remove();},300);},4000);
  });
  document.getElementById('btnPrint').addEventListener('click',function(){window.print();});
  apply();
}());
</script>
