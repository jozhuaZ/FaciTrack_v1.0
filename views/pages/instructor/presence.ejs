<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">

<div class="instructor-layout">
    <%- include('../../partials/instructor-sidebar', { activePage: 'presence', pendingCount: pendingCount }) %>

    <main class="instructor-main">
        <div class="main-container">

            <div class="page-header">
                <div>
                    <h1 class="page-title">Presence Logs</h1>
                    <p class="page-subtitle">BLE SmartTag detection history and real-time monitoring</p>
                </div>
                <div class="header-actions">
                    <div class="ble-live-status <%= instructor.bleStatus %>">
                        <span class="ble-indicator-mini <%= instructor.bleStatus %>">
                            <span class="ble-pulse-mini"></span>
                            <span class="ble-dot-mini"></span>
                        </span>
                        <span><%= instructor.bleStatus === 'in-room' ? 'Currently In Room' : 'Currently Out of Room' %></span>
                    </div>
                    <button class="btn-header-action" id="btnExportLogs">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        Export Logs
                    </button>
                </div>
            </div>

            <!-- Summary Cards -->
            <div class="stats-overview">
                <div class="stat-card-large confirmed">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total Entries Today</p>
                        <h2 class="stat-card-value"><%= presenceLogs.filter(l => l.status === 'entered' && l.timestamp.includes('2026-03-17')).length %></h2>
                        <p class="stat-card-sublabel">BLE detections</p>
                    </div>
                </div>
                <div class="stat-card-large workload">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Hours Logged Today</p>
                        <h2 class="stat-card-value">3.5h</h2>
                        <p class="stat-card-sublabel">Active presence time</p>
                    </div>
                </div>
                <div class="stat-card-large presence">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Location</p>
                        <h2 class="stat-card-value" style="font-size:1.1rem;"><%= instructor.officeRoom %></h2>
                        <p class="stat-card-sublabel">Last detected: <%= instructor.bleLastDetected %></p>
                    </div>
                </div>
            </div>

            <!-- Presence Log Table -->
            <div class="content-card">
                <div class="card-header">
                    <h3 class="card-title">Detection History</h3>
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        <select class="modal-select" id="logFilter" style="padding:0.375rem 0.75rem;font-size:0.8125rem;">
                            <option value="all">All Events</option>
                            <option value="entered">Entries Only</option>
                            <option value="exited">Exits Only</option>
                        </select>
                    </div>
                </div>
                <div class="card-body" style="padding:0;">
                    <table class="data-table" id="presenceTable">
                        <thead>
                            <tr>
                                <th>Event</th>
                                <th>Location</th>
                                <th>Timestamp</th>
                                <th>Duration</th>
                                <th>Detection Method</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% presenceLogs.forEach(log => { %>
                            <tr data-event="<%= log.status %>">
                                <td>
                                    <div class="presence-event-cell">
                                        <span class="presence-row-icon <%= log.status %>" style="width:28px;height:28px;border-radius:6px;display:inline-flex;align-items:center;justify-content:center;">
                                            <% if (log.status === 'entered') { %>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                                            <% } else { %>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                            <% } %>
                                        </span>
                                        <span><%= log.status === 'entered' ? 'Entered' : 'Exited' %></span>
                                    </div>
                                </td>
                                <td><%= log.location %></td>
                                <td><%= log.timestamp %></td>
                                <td><%= log.duration || '—' %></td>
                                <td><span class="table-badge confirmed">BLE SmartTag</span></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <div class="pagination-bar">
                    <span class="page-info" id="pageInfo"></span>
                    <div class="pagination-controls" id="presencePgCtrl"></div>
                </div>
            </div>

        </div>
    </main>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
const ROWS_PER_PAGE = 10;
let currentPage = 1;

function getVisibleRows() {
    const val = document.getElementById('logFilter').value;
    return Array.from(document.querySelectorAll('#presenceTable tbody tr')).filter(row =>
        val === 'all' || row.dataset.event === val
    );
}

function renderPage() {
    const rows = getVisibleRows();
    const totalPages = Math.max(1, Math.ceil(rows.length / ROWS_PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;

    document.querySelectorAll('#presenceTable tbody tr').forEach(r => r.style.display = 'none');
    rows.slice((currentPage - 1) * ROWS_PER_PAGE, currentPage * ROWS_PER_PAGE).forEach(r => r.style.display = '');

    const total = rows.length;
    const from = total ? ((currentPage - 1) * ROWS_PER_PAGE) + 1 : 0;
    const to = Math.min(currentPage * ROWS_PER_PAGE, total);
    document.getElementById('pageInfo').textContent = total ? `Showing ${from}–${to} of ${total}` : 'No results found';
    const ctrl = document.getElementById('presencePgCtrl');
    ctrl.innerHTML = '';
    if (totalPages > 1) {
        const prev = document.createElement('button');
        prev.className = 'pg-btn pg-arrow';
        prev.innerHTML = '&#8592;';
        prev.disabled = currentPage === 1;
        prev.addEventListener('click', () => { currentPage--; renderPage(); });
        ctrl.appendChild(prev);

        let s = Math.max(1, currentPage - 2);
        let e = Math.min(totalPages, s + 4);
        s = Math.max(1, e - 4);
        for (let i = s; i <= e; i++) {
            const b = document.createElement('button');
            b.className = `pg-btn${i === currentPage ? ' active' : ''}`;
            b.textContent = i;
            b.addEventListener('click', () => { currentPage = i; renderPage(); });
            ctrl.appendChild(b);
        }

        const next = document.createElement('button');
        next.className = 'pg-btn pg-arrow';
        next.innerHTML = '&#8594;';
        next.disabled = currentPage >= totalPages;
        next.addEventListener('click', () => { currentPage++; renderPage(); });
        ctrl.appendChild(next);
    }
}

function showToast(type, title, message) {
    const c = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.innerHTML = `<div class="toast-content"><p class="toast-title">${title}</p><p class="toast-message">${message}</p></div>`;
    c.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 4000);
}

document.getElementById('logFilter').addEventListener('change', () => { currentPage = 1; renderPage(); });
document.getElementById('btnExportLogs').addEventListener('click', () => showToast('success', 'Exported', 'Presence logs exported successfully.'));

renderPage();
</script>
