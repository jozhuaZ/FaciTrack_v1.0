<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
*{box-sizing:border-box}
.mo-pill-group{display:flex;gap:.4rem;margin-top:.2rem}
.mo-pill{flex:1;padding:.45rem .5rem;border:1.5px solid #e2e8f0;border-radius:8px;background:#fff;font-size:.8rem;font-weight:600;color:#475569;cursor:pointer;transition:all .15s;font-family:inherit}
.mo-pill:hover{border-color:#2563eb;color:#2563eb}
.mo-pill.active{background:#2563eb;border-color:#2563eb;color:#fff}
.wl-summary{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2rem}
.wl-stat{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:.9rem 1.1rem;display:flex;align-items:center;gap:.75rem;box-shadow:0 2px 8px rgba(0,0,0,.04);transition:all .2s}
.wl-stat:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(0,0,0,.09)}
.wl-stat-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.wl-stat-icon.blue{background:rgba(37,99,235,.12);color:#2563eb}
.wl-stat-icon.green{background:rgba(22,163,74,.12);color:#16a34a}
.wl-stat-icon.purple{background:rgba(124,58,237,.12);color:#7c3aed}
.wl-stat-icon.orange{background:rgba(234,88,12,.12);color:#ea580c}
.wl-stat-val{font-size:1.45rem;font-weight:800;color:#0f172a;line-height:1}
.wl-stat-lbl{font-size:.72rem;color:#64748b;margin-top:2px}
#wlTable{width:100%;border-collapse:separate;border-spacing:0;min-width:720px;font-size:.8rem}
#wlTable th{background:linear-gradient(135deg,rgba(10,61,98,.06),rgba(30,136,229,.08));font-weight:700;font-size:.7rem;text-transform:uppercase;letter-spacing:.07em;color:#475569;padding:.65rem .5rem;text-align:center;border:1px solid #e2e8f0}
#wlTable th:first-child{width:90px;background:#f8fafc}
#wlTable th[data-day="Monday"]{border-top:3px solid #3b82f6}
#wlTable th[data-day="Tuesday"]{border-top:3px solid #8b5cf6}
#wlTable th[data-day="Wednesday"]{border-top:3px solid #06b6d4}
#wlTable th[data-day="Thursday"]{border-top:3px solid #f59e0b}
#wlTable th[data-day="Friday"]{border-top:3px solid #10b981}
#wlTable td.tc{background:#f8fafc;font-size:.7rem;font-weight:700;color:#94a3b8;padding:.4rem .5rem;text-align:center;border:1px solid #e2e8f0;border-right:2px solid #e2e8f0}
#wlTable td.slot{height:58px;vertical-align:top;cursor:pointer;transition:background .12s;padding:3px;border:1px solid #e2e8f0}
#wlTable td.slot:hover{background:rgba(37,99,235,.04)}
.blk{display:flex;flex-direction:column;justify-content:center;align-items:center;height:100%;min-height:52px;padding:.35rem .4rem;border-radius:7px;font-weight:700;color:#fff;text-align:center;line-height:1.25;cursor:pointer;user-select:none;position:relative;transition:filter .12s,transform .1s;box-shadow:0 2px 6px rgba(0,0,0,.18)}
.blk:hover{filter:brightness(1.1);transform:scale(1.02)}
.blk .b-subj{font-size:.74rem;font-weight:800}
.blk .b-room{font-size:.63rem;opacity:.9;margin-top:2px}
.blk .b-sect{font-size:.58rem;opacity:.8;margin-top:1px;text-transform:uppercase}
.blk .b-duration{position:absolute;bottom:3px;right:3px;background:rgba(255,255,255,.3);border-radius:4px;font-size:.58rem;padding:1px 5px;font-weight:700}
.blk .b-edit{position:absolute;top:3px;right:3px;background:rgba(255,255,255,.25);border:none;border-radius:4px;color:#fff;font-size:.58rem;padding:1px 5px;cursor:pointer;opacity:0;transition:opacity .12s}
.blk:hover .b-edit{opacity:1}
.add-hint{display:flex;align-items:center;justify-content:center;height:100%;color:#cbd5e1;font-size:.72rem;gap:3px;opacity:0;transition:opacity .15s;flex-direction:column}
.slot:hover .add-hint{opacity:1}
.mo{display:none;position:fixed;inset:0;background:rgba(15,23,42,.55);z-index:9999;align-items:center;justify-content:center;padding:1rem;backdrop-filter:blur(3px)}
.mo.open{display:flex}
.mo-box{background:#fff;border-radius:16px;width:100%;max-width:440px;box-shadow:0 24px 64px rgba(0,0,0,.25);animation:moIn .2s;overflow:hidden}
@keyframes moIn{from{opacity:0;transform:scale(.93) translateY(10px)}to{opacity:1;transform:none}}

.mo-head{padding:1.25rem 1.5rem 1rem;border-bottom:1px solid #f1f5f9;display:flex;justify-content:space-between;gap:1rem}
.mo-head h3{font-size:1.05rem;font-weight:800;margin:0 0 .2rem;color:#0f172a}
.mo-meta{font-size:.78rem;color:#64748b;margin:0}
.mo-close{width:30px;height:30px;border:none;background:#f1f5f9;border-radius:8px;color:#64748b;cursor:pointer;display:flex;align-items:center;justify-content:center}
.mo-close:hover{background:#e2e8f0;color:#334155}
.mo-body{padding:1.25rem 1.5rem}
.mo-field{margin-bottom:.85rem}
.mo-field label{display:block;font-size:.71rem;font-weight:700;color:#475569;margin-bottom:.3rem;text-transform:uppercase}
.mo-field input,.mo-field select{width:100%;padding:.5rem .75rem;border:1.5px solid #e2e8f0;border-radius:9px;font-size:.84rem;color:#0f172a;outline:none;font-family:inherit;background:#fff}
.mo-field input:focus,.mo-field select:focus{border-color:#2563eb;box-shadow:0 0 0 3px rgba(37,99,235,.1)}
.mo-row{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}
.mo-foot{padding:1rem 1.5rem;border-top:1px solid #f1f5f9;display:flex;gap:.5rem;justify-content:flex-end;background:#fafafa}
.btn{padding:.5rem 1.15rem;border-radius:9px;font-size:.82rem;font-weight:700;cursor:pointer;border:none;font-family:inherit;display:inline-flex;align-items:center;gap:.35rem}
.btn-ghost{background:#f1f5f9;color:#475569}
.btn-primary{background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff}
.btn-danger{background:#fef2f2;color:#dc2626;border:1.5px solid #fecaca}
.btn-danger:hover{background:#dc2626;color:#fff}
.toast-wrap{position:fixed;bottom:1.5rem;right:1.5rem;z-index:99999;display:flex;flex-direction:column;gap:.4rem}
.toast{background:#0f172a;color:#fff;padding:.65rem 1.1rem;border-radius:10px;font-size:.8rem;font-weight:600;box-shadow:0 6px 20px rgba(0,0,0,.25);animation:toastIn .22s;display:flex;align-items:center;gap:.5rem}
.toast.success{background:linear-gradient(135deg,#16a34a,#15803d)}
.toast.error{background:linear-gradient(135deg,#dc2626,#b91c1c)}
.toast.info{background:linear-gradient(135deg,#2563eb,#1d4ed8)}
@keyframes toastIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
@media print{.instructor-sidebar,.page-header .header-actions,.wl-summary{display:none!important}}
@media(max-width:768px){.wl-summary{grid-template-columns:repeat(2,1fr)}.mo-row{grid-template-columns:1fr}}
@media(max-width:640px){
  #legendTable{min-width:520px}
  .legend-table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}
}
@media(max-width:480px){
  /* Keep workload edit modal as a dialog on mobile (not full-screen). */
  .mo{align-items:center;padding:1rem}
  .mo-box{
    width:min(100%,420px);
    max-width:420px;
    max-height:85vh;
    border-radius:14px;
    overflow:auto;
  }
  .mo-head{padding:1rem 1rem .85rem}
  .mo-body{padding:1rem}
  .mo-foot{padding:.85rem 1rem}
  .mo-close{
    width:34px;
    height:34px;
    font-size:1rem;
    font-weight:700;
    border:1px solid #cbd5e1;
    background:#f8fafc;
  }
}
</style>

<div class="instructor-layout">
  <%- include('../../partials/instructor-sidebar', { activePage: 'workload', pendingCount: pendingCount }) %>
  <main class="instructor-main">
    <div class="main-container">
      <div class="page-header">
        <div>
          <h1 class="page-title">Workload Schedule</h1>
          <p class="page-subtitle">Weekly class timetable — click any cell to add or edit</p>
        </div>
        <div class="header-actions">
          <button class="btn-header-action" id="btnExport">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export
          </button>
          <button class="btn-header-action" id="btnClear">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
            Clear All
          </button>
          <button class="btn-header-action" id="btnPrint">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            Print
          </button>
          <span id="autoSaveStatus" style="font-size:.75rem;color:#94a3b8;display:flex;align-items:center;gap:.35rem;padding:.4rem .6rem">
            <svg id="autoSaveIcon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            <span id="autoSaveText">All changes saved</span>
          </span>
        </div>
      </div>

      <div class="wl-summary">
        <div class="wl-stat">
          <div class="wl-stat-icon blue"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
          <div><div class="wl-stat-val" id="statBlocks">0</div><div class="wl-stat-lbl">Total Blocks</div></div>
        </div>
        <div class="wl-stat">
          <div class="wl-stat-icon green"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
          <div><div class="wl-stat-val" id="statHours">0</div><div class="wl-stat-lbl">Teaching Hours/Week</div></div>
        </div>
        <div class="wl-stat">
          <div class="wl-stat-icon purple"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></div>
          <div><div class="wl-stat-val" id="statSubjects">0</div><div class="wl-stat-lbl">Subjects</div></div>
        </div>
        <div class="wl-stat">
          <div class="wl-stat-icon orange"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
          <div><div class="wl-stat-val" id="statRooms">0</div><div class="wl-stat-lbl">Rooms Used</div></div>
        </div>
      </div>

      <div class="content-card">
        <div class="card-header">
          <h3 class="card-title"><%= instructor.name %> — Weekly Schedule</h3>
          <span style="font-size:.75rem;color:#94a3b8">Click empty cell to add · Click block to edit/remove</span>
        </div>
        <div class="card-body" style="padding:0;overflow-x:auto">
          <table id="wlTable">
            <thead>
              <tr>
                <th>TIME</th>
                <th data-day="Monday">MONDAY</th>
                <th data-day="Tuesday">TUESDAY</th>
                <th data-day="Wednesday">WEDNESDAY</th>
                <th data-day="Thursday">THURSDAY</th>
                <th data-day="Friday">FRIDAY</th>
              </tr>
            </thead>
            <tbody id="wlBody"></tbody>
          </table>
        </div>
      </div>

      <div class="content-card">
        <div class="card-header">
          <h3 class="card-title">Subject Legend</h3>
        </div>
        <div class="card-body legend-table-wrap" style="padding:0">
          <table id="legendTable" style="width:100%;border-collapse:collapse">
            <thead>
              <tr style="background:#f8fafc;border-bottom:2px solid #e2e8f0">
                <th style="padding:.65rem 1rem;text-align:left;font-size:.72rem;font-weight:700;color:#475569;text-transform:uppercase;width:110px">Color</th>
                <th style="padding:.65rem 1rem;text-align:left;font-size:.72rem;font-weight:700;color:#475569;text-transform:uppercase;width:150px">Subject Code</th>
                <th style="padding:.65rem 1rem;text-align:left;font-size:.72rem;font-weight:700;color:#475569;text-transform:uppercase">Subject Name</th>
              </tr>
            </thead>
            <tbody id="legendBody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>


<div class="mo" id="cellModal">
  <div class="mo-box">
    <div class="mo-head">
      <div style="flex:1">
        <h3 id="cmTitle">Add Class Block</h3>
        <p class="mo-meta"><span id="cmMetaText"></span></p>
      </div>
      <button class="mo-close" id="cmClose">×</button>
    </div>
    <div class="mo-body">
      <div class="mo-row">
        <div class="mo-field">
          <label>Subject Code</label>
          <input type="text" id="cmSubjectCode" placeholder="e.g. ITEC 321">
        </div>
        <div class="mo-field">
          <label>Subject Name</label>
          <input type="text" id="cmSubjectName" placeholder="e.g. Web Systems 3">
        </div>
      </div>
      <div class="mo-row">
        <div class="mo-field">
          <label>Room / Venue</label>
          <input type="text" id="cmRoom" placeholder="e.g. Room 4">
        </div>
        <div class="mo-field">
          <label>Section</label>
          <input type="text" id="cmSection" placeholder="e.g. BSIT 3-A">
        </div>
      </div>
      <div class="mo-row">
        <div class="mo-field">
          <label>Duration</label>
          <div class="mo-pill-group" id="cmDurationGroup">
            <button type="button" class="mo-pill active" data-val="2">2 Hours</button>
            <button type="button" class="mo-pill" data-val="3">3 Hours</button>
          </div>
          <input type="hidden" id="cmDuration" value="2">
        </div>
        <div class="mo-field">
          <label>Class Type</label>
          <div class="mo-pill-group" id="cmTypeGroup">
            <button type="button" class="mo-pill active" data-val="Lecture">Lecture</button>
            <button type="button" class="mo-pill" data-val="Laboratory">Laboratory</button>
          </div>
          <input type="hidden" id="cmType" value="Lecture">
        </div>
      </div>
      <div class="mo-field">
        <label>Block Color</label>
        <div id="cmColorRow" style="display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.3rem"></div>
      </div>
    </div>
    <div class="mo-foot">
      <button class="btn btn-danger" id="cmRemove" style="margin-right:auto;display:none">Remove</button>
      <button class="btn btn-ghost" id="cmCancel">Cancel</button>
      <button class="btn btn-primary" id="cmSave">Save</button>
    </div>
  </div>
</div>

<div class="mo" id="subjModal">
  <div class="mo-box">
    <div class="mo-head">
      <div style="flex:1">
        <h3 id="smTitle">Add Subject</h3>
        <p class="mo-meta">Define a subject code, name, and color tag.</p>
      </div>
      <button class="mo-close" id="smClose">×</button>
    </div>
    <div class="mo-body">
      <div class="mo-row">
        <div class="mo-field">
          <label>Subject Code</label>
          <input type="text" id="smCode" placeholder="e.g. ITEC 321">
        </div>
        <div class="mo-field">
          <label>Units</label>
          <input type="number" id="smUnits" placeholder="3" min="1" max="6">
        </div>
      </div>
      <div class="mo-field">
        <label>Subject Name</label>
        <input type="text" id="smName" placeholder="e.g. Web Systems and Technologies 3">
      </div>
      <div class="mo-field">
        <label>Color Tag</label>
        <div id="colorRow" style="display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.3rem"></div>
      </div>
    </div>
    <div class="mo-foot">
      <button class="btn btn-danger" id="smDelete" style="margin-right:auto;display:none">Delete</button>
      <button class="btn btn-ghost" id="smCancel">Cancel</button>
      <button class="btn btn-primary" id="smSave">Save Subject</button>
    </div>
  </div>
</div>

<div class="mo" id="clearModal">
  <div class="mo-box" style="max-width:360px">
    <div class="mo-head">
      <div style="flex:1">
        <h3>Clear All Schedule?</h3>
        <p class="mo-meta">This removes all class blocks. Subjects in the legend will remain.</p>
      </div>
    </div>
    <div class="mo-foot">
      <button class="btn btn-ghost" id="clearCancel">Cancel</button>
      <button class="btn btn-danger" id="clearConfirm">Yes, Clear All</button>
    </div>
  </div>
</div>

<div class="mo" id="exportModal">
  <div class="mo-box" style="max-width:480px">
    <div class="mo-head">
      <div style="flex:1">
        <h3>Export Workload</h3>
        <p class="mo-meta">Configure export details for your workload schedule</p>
      </div>
      <button class="mo-close" id="exportClose">×</button>
    </div>
    <div class="mo-body">
      <div class="mo-field">
        <label>Semester</label>
        <input type="text" id="exportSemester" placeholder="e.g. Second Semester" value="Second Semester">
      </div>
      <div class="mo-field">
        <label>School Year</label>
        <input type="text" id="exportSchoolYear" placeholder="e.g. 2100-2101" value="">
      </div>
      <div class="mo-field">
        <label>Effective Date <span style="font-weight:400;color:#94a3b8">(optional)</span></label>
        <input type="text" id="exportEffectiveDate" placeholder="e.g. April 2026">
      </div>
    </div>
    <div class="mo-foot">
      <button class="btn btn-ghost" id="exportCancel">Cancel</button>
      <button class="btn btn-primary" id="exportConfirm">Export as PDF</button>
    </div>
  </div>
</div>

<div id="printableWorkload" style="display:none;background:#fff;padding:40px;width:1200px;margin:0 auto">
  <!-- Content will be generated dynamically -->
</div>

<div class="toast-wrap" id="toastWrap"></div>

<%- include('../../partials/script') %>
<script src="/js/workload.js?v=<%= Date.now() %>"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<%- include('../../partials/footer') %>
