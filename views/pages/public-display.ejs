<%- include('../partials/header') %>
<style>
    html, body { overflow: auto !important; height: auto !important; }

    .display-wrapper {
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem 1.5rem 3rem;
    }

    .display-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        gap: 1rem;
    }

    .display-header h1 {
        font-size: 1.35rem;
        color: var(--primary-blue);
        margin-bottom: 0.15rem;
    }

    .display-header p {
        font-size: 0.82rem;
        color: var(--gray-500);
    }

    .live-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
        border-radius: var(--radius-full);
        padding: 5px 14px;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        flex-shrink: 0;
    }

    .live-dot {
        width: 7px;
        height: 7px;
        background: #16a34a;
        border-radius: 50%;
        animation: blink 1.5s infinite;
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }

    .search-wrap {
        position: relative;
        margin-bottom: 1.25rem;
    }

    .search-wrap svg {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--gray-400);
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        padding: 0.65rem 1rem 0.65rem 2.4rem;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg);
        font-size: 0.9rem;
        font-family: var(--font-body);
        background: #fff;
        color: var(--gray-800);
        outline: none;
        box-shadow: var(--shadow-sm);
        transition: border-color 0.2s;
    }

    .search-input:focus {
        border-color: var(--secondary-teal);
    }

    .faculty-list {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.6rem;
    }

    .faculty-row {
        background: #fff;
        border: 1px solid var(--gray-200);
        border-radius: var(--radius-lg);
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: var(--shadow-sm);
    }

    .faculty-row.hidden { display: none; }

    @media (max-width: 540px) {
        .faculty-list { grid-template-columns: 1fr; }
    }

    .faculty-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--gray-900);
    }

    .status-badge {
        padding: 5px 18px;
        border-radius: var(--radius-full);
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        flex-shrink: 0;
    }

    .status-badge.in {
        background: #f0fdf4;
        color: #16a34a;
        border: 1px solid #bbf7d0;
    }

    .status-badge.out {
        background: var(--gray-100);
        color: var(--gray-400);
        border: 1px solid var(--gray-200);
    }

    .no-results {
        text-align: center;
        padding: 2rem;
        color: var(--gray-400);
        font-size: 0.88rem;
        display: none;
    }
</style>

<main>
    <div class="display-wrapper">

        <div class="display-header">
            <div>
                <h1>Faculty Availability</h1>
                <p>CCS Faculty Lounge</p>
            </div>
            <div class="live-pill">
                <span class="live-dot"></span>
                LIVE
            </div>
        </div>

        <div class="search-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" class="search-input" id="searchInput" placeholder="Search instructor by name..." oninput="filterFaculty()">
        </div>

        <div class="faculty-list" id="facultyList">
            <% faculty.forEach(f => { %>
            <% const isIn = f.bleStatus === 'in-room'; %>
            <div class="faculty-row" data-name="<%= f.name.toLowerCase() %>">
                <span class="faculty-name"><%= f.name %></span>
                <span class="status-badge <%= isIn ? 'in' : 'out' %>"><%= isIn ? 'IN' : 'OUT' %></span>
            </div>
            <% }); %>
        </div>

        <p class="no-results" id="noResults">No instructor found.</p>

    </div>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/script') %>
<script>
    function filterFaculty() {
        const q = document.getElementById('searchInput').value.toLowerCase().trim();
        const rows = document.querySelectorAll('#facultyList .faculty-row');
        let visible = 0;
        rows.forEach(row => {
            const match = row.dataset.name.includes(q);
            row.classList.toggle('hidden', !match);
            if (match) visible++;
        });
        document.getElementById('noResults').style.display = visible === 0 ? 'block' : 'none';
    }

    setTimeout(() => location.reload(), 30000);
</script>
