<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
    .settings-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .settings-section-desc { font-size: 0.8125rem; color: var(--gray-500); margin: 0 0 1.25rem; padding-bottom: 1rem; border-bottom: 1px solid var(--gray-100); }
    .settings-group { display: flex; flex-direction: column; gap: 1rem; }
    .settings-field { display: flex; flex-direction: column; gap: 0.375rem; }
    .settings-label { font-size: 0.8125rem; font-weight: 600; color: var(--gray-700); }
    .settings-input { padding: 0.625rem 0.875rem; border: 1.5px solid var(--gray-300); border-radius: var(--radius-md); font-size: 0.875rem; color: var(--gray-900); background: white; transition: border-color 0.2s; width: 100%; box-sizing: border-box; }
    .settings-input:focus { outline: none; border-color: var(--primary-blue); box-shadow: 0 0 0 3px rgba(10,61,98,0.08); }
    .settings-toggle-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.875rem; border: 1px solid var(--gray-200); border-radius: var(--radius-md); background: white; transition: border-color 0.2s, background 0.2s; }
    .settings-toggle-row:hover { border-color: var(--primary-blue); background: rgba(10,61,98,0.02); }
    .settings-toggle-label { font-size: 0.875rem; font-weight: 600; color: var(--gray-900); margin: 0 0 0.125rem; }
    .settings-toggle-desc { font-size: 0.75rem; color: var(--gray-500); margin: 0; line-height: 1.4; }
    .toggle-switch { position: relative; width: 44px; height: 24px; flex-shrink: 0; }
    .toggle-switch input { opacity: 0; width: 0; height: 0; position: absolute; }
    .toggle-slider { position: absolute; cursor: pointer; inset: 0; background: var(--gray-300); border-radius: 24px; transition: 0.3s; }
    .toggle-slider:before { content: ''; position: absolute; width: 18px; height: 18px; left: 3px; bottom: 3px; background: white; border-radius: 50%; transition: 0.3s; box-shadow: 0 1px 4px rgba(0,0,0,0.2); }
    input:checked + .toggle-slider { background: var(--primary-blue); }
    input:checked + .toggle-slider:before { transform: translateX(20px); }
    @media (max-width: 900px) { .settings-grid { grid-template-columns: 1fr; } }
</style>

<div class="instructor-layout">
    <%- include('../../partials/admin-sidebar', { activePage: 'settings' }) %>
    <main class="instructor-main">
        <div class="main-container">

            <div class="page-header">
                <div>
                    <h1 class="page-title">System Settings</h1>
                    <p class="page-subtitle">Configure system parameters and feature toggles for FaciTrack — College of Computer Studies.</p>
                </div>
                <div class="header-actions">
                    <button class="btn-header-action" onclick="resetForm()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.5"/></svg>
                        Reset
                    </button>
                    <button class="btn-header-action primary" onclick="saveSettings()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Save Changes
                    </button>
                </div>
            </div>

            <div class="settings-grid">

                <!-- General Configuration -->
                <div class="content-card">
                    <div class="card-header">
                        <h3 class="card-title">General Configuration</h3>
                    </div>
                    <div class="card-body">
                        <div class="settings-group">
                            <% settings.slice(0, 4).forEach(s => { %>
                            <div class="settings-field">
                                <label class="settings-label"><%= s.label %></label>
                                <input type="text" class="settings-input" value="<%= s.value %>">
                            </div>
                            <% }); %>
                        </div>
                    </div>
                </div>

                <!-- BLE & Monitoring -->
                <div class="content-card">
                    <div class="card-header">
                        <h3 class="card-title">BLE & Monitoring</h3>
                    </div>
                    <div class="card-body">
                        <div class="settings-group">
                            <% settings.slice(4, 8).forEach(s => { %>
                            <div class="settings-field">
                                <label class="settings-label"><%= s.label %></label>
                                <input type="text" class="settings-input" value="<%= s.value %>">
                            </div>
                            <% }); %>
                        </div>
                    </div>
                </div>

                <!-- Appointment Settings -->
                <div class="content-card">
                    <div class="card-header">
                        <h3 class="card-title">Appointment Settings</h3>
                    </div>
                    <div class="card-body">
                        <div class="settings-group">
                            <% settings.slice(8).forEach(s => { %>
                            <div class="settings-field">
                                <label class="settings-label"><%= s.label %></label>
                                <input type="text" class="settings-input" value="<%= s.value %>">
                            </div>
                            <% }); %>
                        </div>
                    </div>
                </div>

                <!-- Feature Toggles -->
                <div class="content-card">
                    <div class="card-header">
                        <h3 class="card-title">Feature Toggles</h3>
                    </div>
                    <div class="card-body">
                        <p class="settings-section-desc">Enable or disable system features without code changes.</p>
                        <div class="settings-group">
                            <% toggles.forEach(t => { %>
                            <div class="settings-toggle-row">
                                <div>
                                    <p class="settings-toggle-label"><%= t.label %></p>
                                    <p class="settings-toggle-desc"><%= t.description %></p>
                                </div>
                                <label class="toggle-switch">
                                    <input type="checkbox" <%= t.enabled ? 'checked' : '' %>>
                                    <span class="toggle-slider"></span>
                                </label>
                            </div>
                            <% }); %>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
function showToast(type, title, message) {
    const c = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.innerHTML = `<div class="toast-content"><p class="toast-title">${title}</p><p class="toast-message">${message}</p></div>`;
    c.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 4000);
}
function saveSettings() { showToast('success', 'Settings Saved', 'System configuration has been updated successfully.'); }
function resetForm() { showToast('success', 'Reset', 'Settings have been reset to defaults.'); }
</script>
