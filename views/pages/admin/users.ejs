<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
    html, body { overflow: hidden !important; height: 100vh !important; }
    body { display: flex; flex-direction: column; }
    main { flex: 1; min-height: 0; display: flex; flex-direction: column; }
</style>

<div class="instructor-layout">
    <%- include('../../partials/admin-sidebar', { activePage: 'users' }) %>
    <main class="instructor-main">
        <div class="main-container">

            <div class="page-header">
                <div>
                    <h1 class="page-title">User Accounts</h1>
                    <p class="page-subtitle">Manage instructor and dean accounts registered in the system.</p>
                </div>
                <div class="header-actions">
                    <button class="btn-header-action primary" id="btnAddUser">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Add User
                    </button>
                </div>
            </div>

            <!-- Stats -->
            <div class="stats-overview">
                <div class="stat-card-large confirmed">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total Users</p>
                        <h2 class="stat-card-value"><%= users.length %></h2>
                        <p class="stat-card-sublabel">All registered accounts</p>
                    </div>
                </div>
                <div class="stat-card-large pending">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Instructors</p>
                        <h2 class="stat-card-value"><%= users.filter(u => u.role === 'Instructor').length %></h2>
                        <p class="stat-card-sublabel">Faculty accounts</p>
                    </div>
                </div>
                <div class="stat-card-large workload">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Active</p>
                        <h2 class="stat-card-value"><%= users.filter(u => u.status === 'active').length %></h2>
                        <p class="stat-card-sublabel">Enabled accounts</p>
                    </div>
                </div>
                <div class="stat-card-large presence">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Inactive</p>
                        <h2 class="stat-card-value"><%= users.filter(u => u.status === 'inactive').length %></h2>
                        <p class="stat-card-sublabel">Disabled accounts</p>
                    </div>
                </div>
            </div>

            <!-- Table -->
            <div class="content-card">
                <div class="card-header">
                    <h3 class="card-title">All Users (<span id="visibleCount"><%= users.length %></span>)</h3>
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        <select class="modal-select" id="filterRole" onchange="applyFilters()" style="padding:0.375rem 0.75rem;font-size:0.8125rem;">
                            <option value="">All Roles</option>
                            <option value="Instructor">Instructor</option>
                            <option value="Dean">Dean</option>
                            <option value="Admin">Admin</option>
                        </select>
                        <select class="modal-select" id="filterStatus" onchange="applyFilters()" style="padding:0.375rem 0.75rem;font-size:0.8125rem;">
                            <option value="">All Status</option>
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                        <input type="text" class="modal-select" id="searchInput" placeholder="Search name or email..." oninput="applyFilters()" style="padding:0.375rem 0.75rem;font-size:0.8125rem;width:180px;">
                    </div>
                </div>
                <div class="card-body" style="padding:0;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Department</th>
                                <th>Status</th>
                                <th>Last Login</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="usersTableBody">
                            <% users.forEach((u, i) => { %>
                            <tr data-role="<%= u.role %>" data-status="<%= u.status %>" data-name="<%= u.name.toLowerCase() %>" data-email="<%= u.email.toLowerCase() %>">
                                <td style="color:var(--gray-400);font-size:0.8125rem;"><%= i + 1 %></td>
                                <td>
                                    <div style="display:flex;align-items:center;gap:0.625rem;">
                                        <div class="apt-avatar-xs" style="width:34px;height:34px;font-size:0.6875rem;flex-shrink:0;"><%= u.name.split(' ').map(n=>n[0]).join('').slice(0,2) %></div>
                                        <div>
                                            <p style="font-weight:600;font-size:0.875rem;color:var(--gray-900);margin:0;"><%= u.name %></p>
                                        </div>
                                    </div>
                                </td>
                                <td style="color:var(--gray-600);font-size:0.8125rem;"><%= u.email %></td>
                                <td><span class="table-badge <%= u.role === 'Admin' ? 'workload' : u.role === 'Dean' ? 'pending' : 'confirmed' %>"><%= u.role %></span></td>
                                <td style="color:var(--gray-600);font-size:0.8125rem;"><%= u.department %></td>
                                <td><span class="table-badge <%= u.status === 'active' ? 'confirmed' : 'declined' %>"><%= u.status === 'active' ? 'Active' : 'Inactive' %></span></td>
                                <td style="color:var(--gray-500);font-size:0.8125rem;"><%= u.lastLogin %></td>
                                <td>
                                    <div style="display:flex;gap:0.375rem;">
                                        <button class="btn-icon-action approve" title="Edit user" onclick="showToast('success','Edit User','Opening editor for <%= u.name %>...')">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                        </button>
                                        <button class="btn-icon-action decline" title="Deactivate account" onclick="showToast('error','Account Updated','<%= u.name %> has been deactivated.')">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                    <div class="pagination-bar">
                        <button class="btn-page" id="prevBtn" onclick="changePage(-1)">&#8592; Prev</button>
                        <span class="page-info" id="paginationInfo"></span>
                        <button class="btn-page" id="nextBtn" onclick="changePage(1)">Next &#8594;</button>
                    </div>
                </div>
            </div>

        </div>
    </main>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
let currentPage = 1;
const rowsPerPage = 7;

function getAllRows() {
    return Array.from(document.querySelectorAll('#usersTableBody tr'));
}

function applyFilters() {
    const role = document.getElementById('filterRole').value;
    const status = document.getElementById('filterStatus').value;
    const search = document.getElementById('searchInput').value.toLowerCase();
    getAllRows().forEach(r => {
        const matchRole = !role || r.dataset.role === role;
        const matchStatus = !status || r.dataset.status === status;
        const matchSearch = !search || r.dataset.name.includes(search) || r.dataset.email.includes(search);
        r.dataset.filtered = (matchRole && matchStatus && matchSearch) ? 'show' : 'hide';
        r.style.display = 'none';
    });
    currentPage = 1;
    renderPage();
}

function getVisibleRows() {
    return getAllRows().filter(r => r.dataset.filtered !== 'hide');
}

function renderPage() {
    const rows = getVisibleRows();
    const total = rows.length;
    const start = (currentPage - 1) * rowsPerPage;
    const end = start + rowsPerPage;
    rows.forEach((r, i) => r.style.display = (i >= start && i < end) ? '' : 'none');
    document.getElementById('paginationInfo').textContent = total === 0 ? 'No results found' : `Showing ${Math.min(start+1,total)}–${Math.min(end,total)} of ${total}`;
    document.getElementById('prevBtn').disabled = currentPage === 1;
    document.getElementById('nextBtn').disabled = end >= total;
    document.getElementById('visibleCount').textContent = total;
}

function changePage(dir) { currentPage += dir; renderPage(); }

function showToast(type, title, message) {
    const c = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.innerHTML = `<div class="toast-content"><p class="toast-title">${title}</p><p class="toast-message">${message}</p></div>`;
    c.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 4000);
}

document.getElementById('btnAddUser').addEventListener('click', () => showToast('success', 'Add User', 'User creation form coming soon.'));

// init
getAllRows().forEach(r => r.dataset.filtered = 'show');
renderPage();
</script>
