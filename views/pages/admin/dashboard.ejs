<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
    .system-info-row { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid var(--gray-100); }
    .system-info-row:last-child { border-bottom: none; padding-bottom: 0; }
    .system-info-label { font-size: 0.8125rem; color: var(--gray-500); }
    .system-info-value { font-size: 0.875rem; font-weight: 600; color: var(--gray-900); }
    .breakdown-label { min-width: 90px; font-size: 0.8125rem; color: var(--gray-700); font-weight: 500; }
    .breakdown-value { min-width: 28px; text-align: right; font-size: 0.8125rem; font-weight: 700; color: var(--gray-900); }
    .ble-device-row { display: flex; align-items: center; justify-content: space-between; padding: 0.625rem 0; border-bottom: 1px solid var(--gray-100); }
    .ble-device-row:last-child { border-bottom: none; }
    .ble-device-name { font-size: 0.8125rem; font-weight: 600; color: var(--gray-900); }
    .ble-device-room { font-size: 0.72rem; color: var(--gray-400); margin-top: 1px; }
</style>

<div class="instructor-layout">
    <%- include('../../partials/admin-sidebar', { activePage: 'dashboard' }) %>
    <main class="instructor-main">
        <div class="main-container">

            <div class="page-header">
                <div>
                    <h1 class="page-title">Dashboard</h1>
                    <p class="page-subtitle">Welcome, <%= admin.name.split(' ')[0] %>!</p>
                </div>
                <div class="header-actions">
                    <a href="/admin/users" class="btn-header-action primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        Faculty Management
                    </a>
                </div>
            </div>

            <!-- Stats -->
            <div class="stats-overview">
                <div class="stat-card-large confirmed">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total Staff</p>
                        <h2 class="stat-card-value"><%= users.length %></h2>
                        <p class="stat-card-sublabel">Dean + Instructors</p>
                    </div>
                </div>
                <div class="stat-card-large pending">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Instructors</p>
                        <h2 class="stat-card-value"><%= users.filter(u => u.role === 'Instructor').length %></h2>
                        <p class="stat-card-sublabel">Active faculty</p>
                    </div>
                </div>
                <div class="stat-card-large presence">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Rooms</p>
                        <h2 class="stat-card-value"><%= roomData.length %></h2>
                        <p class="stat-card-sublabel">Registered rooms</p>
                    </div>
                </div>
                <div class="stat-card-large workload">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Audit Logs Today</p>
                        <h2 class="stat-card-value"><%= logs.filter(l => l.isToday).length %></h2>
                        <p class="stat-card-sublabel">System events</p>
                    </div>
                </div>
            </div>

            <!-- Content Grid -->
            <div class="dashboard-content-grid">

                <!-- Staff List -->
                <div class="content-card">
                    <div class="card-header">
                        <h3 class="card-title">Staff</h3>
                        <a href="/admin/users" class="card-link">View All →</a>
                    </div>
                    <div class="card-body">
                        <div class="appointments-list-dashboard">
                            <% users.slice(0, 5).forEach(u => { %>
                            <div class="appointment-row">
                                <div class="apt-row-left">
                                    <div class="apt-avatar-xs"><%= u.name.split(' ').map(n => n[0]).join('').slice(0,2) %></div>
                                    <div class="apt-row-info">
                                        <h4 class="apt-row-name"><%= u.name %></h4>
                                        <p class="apt-row-details"><%= u.role %> · <%= u.employmentType %></p>
                                    </div>
                                </div>
                                <span class="table-badge <%= u.status === 'active' ? 'confirmed' : 'declined' %>">
                                    <%= u.status === 'active' ? 'Active' : 'Inactive' %>
                                </span>
                            </div>
                            <% }); %>
                        </div>
                    </div>
                </div>

                <!-- Recent Audit Logs -->
                <div class="content-card">
                    <div class="card-header">
                        <h3 class="card-title">Recent Audit Logs</h3>
                        <a href="/admin/logs" class="card-link">View All →</a>
                    </div>
                    <div class="card-body">
                        <div class="presence-list-dashboard">
                            <% logs.slice(0, 5).forEach(log => { %>
                            <div class="presence-row">
                                <div class="presence-row-icon <%= log.type === 'login' || log.type === 'create' ? 'entered' : 'exited' %>">
                                    <% if (log.type === 'login') { %>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                                    <% } else if (log.type === 'create') { %>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                    <% } else if (log.type === 'update') { %>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    <% } else { %>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                    <% } %>
                                </div>
                                <div class="presence-row-info">
                                    <p class="presence-row-action"><%= log.user %> — <%= log.action %></p>
                                    <p class="presence-row-time"><%= log.timestamp %></p>
                                </div>
                            </div>
                            <% }); %>
                        </div>
                    </div>
                </div>

                <!-- Staff by Employment Type -->
                <div class="content-card">
                    <div class="card-header">
                        <h3 class="card-title">Staff by Employment Type</h3>
                        <a href="/admin/users" class="card-link">Manage →</a>
                    </div>
                    <div class="card-body">
                        <div class="workload-breakdown">
                            <% ['Regular','Part-time','Contractual'].forEach(et => { %>
                            <% const count = users.filter(u => u.employmentType === et).length; %>
                            <div class="breakdown-row">
                                <span class="breakdown-label" style="min-width:100px;font-size:0.8125rem;"><%= et %></span>
                                <div class="breakdown-bar-wrap">
                                    <div class="breakdown-bar" style="width:<%= users.length > 0 ? (count / users.length) * 100 : 0 %>%"></div>
                                </div>
                                <span class="breakdown-value"><%= count %></span>
                            </div>
                            <% }); %>
                        </div>
                        <div style="margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--gray-100);">
                            <div class="system-info-row">
                                <span class="system-info-label">Department</span>
                                <span class="system-info-value" style="color:var(--primary-blue);">College of Computer Studies</span>
                            </div>
                            <div class="system-info-row">
                                <span class="system-info-label">Dean</span>
                                <span class="system-info-value"><%= users.find(u => u.role === 'Dean') ? users.find(u => u.role === 'Dean').name : '—' %></span>
                            </div>
                            <div class="system-info-row">
                                <span class="system-info-label">Active Staff</span>
                                <span class="system-info-value"><%= users.filter(u => u.status === 'active').length %></span>
                            </div>
                            <div class="system-info-row">
                                <span class="system-info-label">Inactive Staff</span>
                                <span class="system-info-value" style="color:<%= users.filter(u=>u.status==='inactive').length > 0 ? '#dc2626' : 'var(--gray-900)' %>"><%= users.filter(u => u.status === 'inactive').length %></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Rooms Overview -->
                <div class="content-card">
                    <div class="card-header">
                        <h3 class="card-title">Rooms Overview</h3>
                        <a href="/admin/rooms" class="card-link">Manage →</a>
                    </div>
                    <div class="card-body">
                        <div class="system-info-row">
                            <span class="system-info-label">Total Rooms</span>
                            <span class="system-info-value"><%= roomData.length %></span>
                        </div>
                        <div class="system-info-row">
                            <span class="system-info-label">BLE Scanners Active</span>
                            <span class="system-info-value" style="color:#16a34a;"><%= roomData.filter(r => r.bleScanner).length %></span>
                        </div>
                        <div class="system-info-row">
                            <span class="system-info-label">Assigned to Faculty</span>
                            <span class="system-info-value"><%= roomData.filter(r => r.assignedFaculty !== 'Unassigned').length %></span>
                        </div>
                        <div class="system-info-row">
                            <span class="system-info-label">Unassigned</span>
                            <span class="system-info-value"><%= roomData.filter(r => r.assignedFaculty === 'Unassigned').length %></span>
                        </div>
                        <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid var(--gray-100);">
                            <% roomData.slice(0, 4).forEach(r => { %>
                            <div class="ble-device-row">
                                <div>
                                    <p class="ble-device-name"><%= r.roomNumber %></p>
                                    <p class="ble-device-room"><%= r.assignedFaculty !== 'Unassigned' ? r.assignedFaculty : 'Unassigned' %></p>
                                </div>
                                <span class="table-badge <%= r.status === 'active' ? 'confirmed' : 'declined' %>" style="font-size:0.65rem;"><%= r.status === 'active' ? 'Active' : 'Inactive' %></span>
                            </div>
                            <% }); %>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
