<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
    .modal-overlay { position:fixed;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:1000;opacity:0;visibility:hidden;transition:all 0.3s ease;padding:1rem; }
    .modal-overlay.show { opacity:1;visibility:visible; }
    .modal-content { background:white;border-radius:var(--radius-lg);box-shadow:0 25px 70px rgba(0,0,0,0.35);max-width:540px;width:100%;transform:scale(0.9);transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1); }
    .modal-overlay.show .modal-content { transform:scale(1); }
    .modal-header { display:flex;justify-content:space-between;align-items:center;padding:1.25rem 1.5rem;border-bottom:1px solid var(--gray-200); }
    .modal-title { font-size:1.125rem;font-weight:700;color:var(--gray-900);margin:0; }
    .modal-close { width:32px;height:32px;border:none;background:transparent;color:var(--gray-500);cursor:pointer;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;transition:all 0.2s; }
    .modal-close:hover { background:var(--gray-100);color:var(--gray-900); }
    .modal-body { padding:1.5rem;display:flex;flex-direction:column;gap:1rem; }
    .modal-footer { display:flex;justify-content:flex-end;gap:0.75rem;padding:1rem 1.5rem;border-top:1px solid var(--gray-200);background:var(--gray-50); }
    .form-field { display:flex;flex-direction:column;gap:0.375rem; }
    .form-field label { font-size:0.8125rem;font-weight:600;color:var(--gray-700); }
    .form-field input, .form-field select { padding:0.625rem 0.875rem;border:1.5px solid var(--gray-300);border-radius:var(--radius-md);font-size:0.875rem;color:var(--gray-900);background:white;font-family:var(--font-body);transition:border-color 0.2s;width:100%;box-sizing:border-box; }
    .form-field input:focus, .form-field select:focus { outline:none;border-color:var(--primary-blue);box-shadow:0 0 0 3px rgba(10,61,98,0.08); }
    .form-row { display:grid;grid-template-columns:1fr 1fr;gap:1rem; }
    .delete-confirm { background:#fef2f2;border:1px solid #fecaca;border-radius:var(--radius-md);padding:1rem;font-size:0.875rem;color:#991b1b;line-height:1.5; }
</style>

<div class="instructor-layout">
    <%- include('../../partials/admin-sidebar', { activePage: 'rooms' }) %>
    <main class="instructor-main">
        <div class="main-container">

            <div class="page-header">
                <div>
                    <h1 class="page-title">Rooms</h1>
                    <p class="page-subtitle">Manage faculty rooms and offices — College of Computer Studies</p>
                </div>
                <div class="header-actions">
                    <button class="btn-header-action primary" id="btnAddRoom">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Add Room
                    </button>
                </div>
            </div>

            <!-- Stats -->
            <div class="stats-overview">
                <div class="stat-card-large confirmed">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total Rooms</p>
                        <h2 class="stat-card-value"><%= roomData.length %></h2>
                        <p class="stat-card-sublabel">CCS Building</p>
                    </div>
                </div>
                <div class="stat-card-large pending">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">BLE Scanners</p>
                        <h2 class="stat-card-value"><%= roomData.filter(r => r.bleScanner).length %></h2>
                        <p class="stat-card-sublabel">Rooms with ESP32</p>
                    </div>
                </div>
                <div class="stat-card-large workload">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Assigned</p>
                        <h2 class="stat-card-value"><%= roomData.filter(r => r.assignedFaculty !== 'Unassigned').length %></h2>
                        <p class="stat-card-sublabel">Rooms with faculty</p>
                    </div>
                </div>
                <div class="stat-card-large presence">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Departments</p>
                        <h2 class="stat-card-value"><%= departments.length %></h2>
                        <p class="stat-card-sublabel">With rooms registered</p>
                    </div>
                </div>
            </div>

            <!-- Table -->
            <div class="content-card">
                <div class="card-header">
                    <h3 class="card-title">All Rooms (<span id="roomCount"><%= roomData.length %></span>)</h3>
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        <select id="roomDeptFilter" onchange="filterRooms()" style="padding:0.375rem 0.75rem;border:1.5px solid var(--gray-200);border-radius:var(--radius-md);font-size:0.8125rem;font-family:var(--font-body);">
                            <option value="all">All Departments</option>
                            <% departments.forEach(d => { %>
                            <option value="<%= d %>"><%= d %></option>
                            <% }); %>
                        </select>
                        <select id="roomTypeFilter" onchange="filterRooms()" style="padding:0.375rem 0.75rem;border:1.5px solid var(--gray-200);border-radius:var(--radius-md);font-size:0.8125rem;font-family:var(--font-body);">
                            <option value="all">All Types</option>
                            <option value="Faculty Office">Faculty Office</option>
                            <option value="Consultation Room">Consultation Room</option>
                            <option value="Laboratory">Laboratory</option>
                            <option value="Faculty Lounge">Faculty Lounge</option>
                        </select>
                        <input type="text" id="roomSearch" placeholder="Search room..." oninput="filterRooms()" style="padding:0.375rem 0.75rem;border:1.5px solid var(--gray-200);border-radius:var(--radius-md);font-size:0.8125rem;width:160px;font-family:var(--font-body);">
                    </div>
                </div>
                <div class="card-body" style="padding:0;">
                    <table class="data-table" id="roomTable">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Room</th>
                                <th>Department</th>
                                <th>Type</th>
                                <th>Assigned Faculty</th>
                                <th>BLE Scanner</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="roomTableBody">
                            <% roomData.forEach((room, i) => { %>
                            <tr data-dept="<%= room.department %>" data-type="<%= room.type %>" data-name="<%= room.roomNumber.toLowerCase() %> <%= room.building.toLowerCase() %>">
                                <td style="color:var(--gray-400);font-size:0.8125rem;"><%= i + 1 %></td>
                                <td>
                                    <div>
                                        <p style="font-weight:700;font-size:0.875rem;color:var(--gray-900);margin:0 0 0.125rem;"><%= room.roomNumber %></p>
                                        <p style="font-size:0.75rem;color:var(--gray-500);margin:0;"><%= room.building %></p>
                                    </div>
                                </td>
                                <td style="font-size:0.8125rem;color:var(--gray-600);"><%= room.department %></td>
                                <td><span class="table-badge pending" style="font-size:0.6875rem;"><%= room.type %></span></td>
                                <td style="font-size:0.8125rem;color:<%= room.assignedFaculty === 'Unassigned' ? 'var(--gray-400)' : 'var(--gray-900)' %>;font-style:<%= room.assignedFaculty === 'Unassigned' ? 'italic' : 'normal' %>;"><%= room.assignedFaculty %></td>
                                <td>
                                    <% if (room.bleScanner) { %>
                                    <span class="table-badge confirmed">ESP32 Active</span>
                                    <% } else { %>
                                    <span class="table-badge" style="background:var(--gray-100);color:var(--gray-500);border:1px solid var(--gray-200);">None</span>
                                    <% } %>
                                </td>
                                <td>
                                    <span class="table-badge <%= room.status === 'active' ? 'confirmed' : 'declined' %>">
                                        <%= room.status === 'active' ? 'Active' : 'Inactive' %>
                                    </span>
                                </td>
                                <td>
                                    <div style="display:flex;gap:0.375rem;">
                                        <button class="btn-icon-action approve" title="Edit room" onclick="openEditRoom(<%= i %>)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                        </button>
                                        <button class="btn-icon-action decline" title="Delete room" onclick="openDeleteRoom('<%= room.roomNumber %>', '<%= room.building %>')">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <div class="pagination-bar">
                    <button class="btn-page" id="btnPrev">&#8592; Prev</button>
                    <span class="page-info" id="pageInfo"></span>
                    <button class="btn-page" id="btnNext">Next &#8594;</button>
                </div>
            </div>

        </div>
    </main>
</div>

<!-- Add/Edit Room Modal -->
<div class="modal-overlay" id="roomModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title" id="roomModalTitle">Add Room</h3>
            <button class="modal-close" onclick="closeRoomModal()">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="form-row">
                <div class="form-field">
                    <label>Room Number <span style="color:#e53e3e;">*</span></label>
                    <input type="text" id="roomNumber" placeholder="Room 201">
                </div>
                <div class="form-field">
                    <label>Building</label>
                    <input type="text" id="roomBuilding" placeholder="CCS Building">
                </div>
            </div>
            <div class="form-row">
                <div class="form-field">
                    <label>Department <span style="color:#e53e3e;">*</span></label>
                    <select id="roomDept">
                        <option value="">Select department...</option>
                        <% departments.forEach(d => { %>
                        <option value="<%= d %>"><%= d %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="form-field">
                    <label>Room Type</label>
                    <select id="roomType">
                        <option value="Faculty Office">Faculty Office</option>
                        <option value="Consultation Room">Consultation Room</option>
                        <option value="Laboratory">Laboratory</option>
                        <option value="Faculty Lounge">Faculty Lounge</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-field">
                    <label>Assigned Faculty</label>
                    <input type="text" id="roomFaculty" placeholder="Dr. Maria Santos">
                </div>
                <div class="form-field">
                    <label>BLE Scanner (ESP32)</label>
                    <select id="roomBle">
                        <option value="false">Not Installed</option>
                        <option value="true">Installed / Active</option>
                    </select>
                </div>
            </div>
            <div class="form-field">
                <label>Status</label>
                <select id="roomStatus">
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-modal btn-cancel" onclick="closeRoomModal()">Cancel</button>
            <button class="btn-modal btn-confirm" style="background:linear-gradient(135deg,var(--primary-blue),#1e88e5);color:white;" onclick="saveRoom()">Save Room</button>
        </div>
    </div>
</div>

<!-- Delete Room Modal -->
<div class="modal-overlay" id="deleteRoomModal">
    <div class="modal-content" style="max-width:420px;">
        <div class="modal-header">
            <h3 class="modal-title">Delete Room</h3>
            <button class="modal-close" onclick="closeDeleteRoomModal()">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="delete-confirm">
                <strong>Delete "<span id="deleteRoomName"></span>"?</strong><br><br>
                Removing this room will also remove its BLE scanner assignment and any faculty room associations. Presence logs for this room will be retained for historical records.
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn-modal btn-cancel" onclick="closeDeleteRoomModal()">Cancel</button>
            <button class="btn-modal btn-confirm" onclick="confirmDeleteRoom()">Delete Room</button>
        </div>
    </div>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
const roomData = <%- JSON.stringify(roomData) %>;
let editingRoomIndex = null;
let deletingRoom = null;
const ROWS_PER_PAGE = 10;
let currentPage = 1;
let visibleRows = [];

function filterRooms() {
    const dept = document.getElementById('roomDeptFilter').value;
    const type = document.getElementById('roomTypeFilter').value;
    const q = document.getElementById('roomSearch').value.toLowerCase();
    visibleRows = Array.from(document.querySelectorAll('#roomTableBody tr')).filter(row => {
        const matchDept = dept === 'all' || row.dataset.dept === dept;
        const matchType = type === 'all' || row.dataset.type === type;
        const matchQ = !q || row.dataset.name.includes(q);
        return matchDept && matchType && matchQ;
    });
    currentPage = 1;
    renderPage();
}

function renderPage() {
    const total = visibleRows.length;
    const totalPages = Math.max(1, Math.ceil(total / ROWS_PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;
    document.querySelectorAll('#roomTableBody tr').forEach(r => r.style.display = 'none');
    visibleRows.slice((currentPage - 1) * ROWS_PER_PAGE, currentPage * ROWS_PER_PAGE).forEach(r => r.style.display = '');
    document.getElementById('pageInfo').textContent = `Page ${currentPage} of ${totalPages} (${total} rooms)`;
    document.getElementById('btnPrev').disabled = currentPage === 1;
    document.getElementById('btnNext').disabled = currentPage === totalPages;
    document.getElementById('roomCount').textContent = total;
}

function openEditRoom(index) {
    const r = roomData[index];
    editingRoomIndex = index;
    document.getElementById('roomModalTitle').textContent = 'Edit Room';
    document.getElementById('roomNumber').value = r.roomNumber;
    document.getElementById('roomBuilding').value = r.building;
    document.getElementById('roomDept').value = r.department;
    document.getElementById('roomType').value = r.type;
    document.getElementById('roomFaculty').value = r.assignedFaculty === 'Unassigned' ? '' : r.assignedFaculty;
    document.getElementById('roomBle').value = String(r.bleScanner);
    document.getElementById('roomStatus').value = r.status;
    document.getElementById('roomModal').classList.add('show');
}

function closeRoomModal() {
    editingRoomIndex = null;
    document.getElementById('roomModal').classList.remove('show');
    document.getElementById('roomModalTitle').textContent = 'Add Room';
    ['roomNumber','roomBuilding','roomFaculty'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('roomDept').value = '';
    document.getElementById('roomType').value = 'Faculty Office';
    document.getElementById('roomBle').value = 'false';
    document.getElementById('roomStatus').value = 'active';
}

function saveRoom() {
    const num = document.getElementById('roomNumber').value.trim();
    const dept = document.getElementById('roomDept').value;
    if (!num) { showToast('error', 'Required', 'Room number is required.'); return; }
    if (!dept) { showToast('error', 'Required', 'Please select a department.'); return; }
    const action = editingRoomIndex !== null ? 'updated' : 'added';
    showToast('success', editingRoomIndex !== null ? 'Room Updated' : 'Room Added', `"${num}" has been ${action} successfully.`);
    closeRoomModal();
}

function openDeleteRoom(roomNum, building) {
    deletingRoom = `${roomNum}, ${building}`;
    document.getElementById('deleteRoomName').textContent = deletingRoom;
    document.getElementById('deleteRoomModal').classList.add('show');
}

function closeDeleteRoomModal() {
    deletingRoom = null;
    document.getElementById('deleteRoomModal').classList.remove('show');
}

function confirmDeleteRoom() {
    showToast('success', 'Room Deleted', `"${deletingRoom}" has been removed.`);
    closeDeleteRoomModal();
}

function showToast(type, title, message) {
    const c = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.innerHTML = `<div class="toast-content"><p class="toast-title">${title}</p><p class="toast-message">${message}</p></div>`;
    c.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 4000);
}

document.getElementById('btnAddRoom').addEventListener('click', () => {
    editingRoomIndex = null;
    document.getElementById('roomModalTitle').textContent = 'Add Room';
    document.getElementById('roomModal').classList.add('show');
});
document.getElementById('btnPrev').addEventListener('click', () => { currentPage--; renderPage(); });
document.getElementById('btnNext').addEventListener('click', () => { currentPage++; renderPage(); });

// init
visibleRows = Array.from(document.querySelectorAll('#roomTableBody tr'));
renderPage();
</script>
