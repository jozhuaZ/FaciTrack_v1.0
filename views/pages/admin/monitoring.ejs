<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
    html, body { overflow: hidden !important; height: 100vh !important; }
    body { display: flex; flex-direction: column; }
    main { flex: 1; min-height: 0; display: flex; flex-direction: column; }
</style>

<div class="instructor-layout">
    <%- include('../../partials/admin-sidebar', { activePage: 'monitoring' }) %>

    <main class="instructor-main">
        <div class="main-container">

            <div class="page-header">
                <div>
                    <h1 class="page-title">Monitoring Logs</h1>
                    <p class="page-subtitle">BLE presence detection history across all CCS faculty rooms</p>
                </div>
                <div class="header-actions">
                    <button class="btn-header-action" id="btnExportLogs">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        Export Logs
                    </button>
                </div>
            </div>

            <div class="stats-overview">
                <div class="stat-card-large confirmed">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total Entries Today</p>
                        <h2 class="stat-card-value"><%= presenceLogs.filter(l => l.status === 'entered').length %></h2>
                        <p class="stat-card-sublabel">BLE detections</p>
                    </div>
                </div>
                <div class="stat-card-large workload">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total Events Today</p>
                        <h2 class="stat-card-value"><%= presenceLogs.length %></h2>
                        <p class="stat-card-sublabel">Entries and exits</p>
                    </div>
                </div>
                <div class="stat-card-large presence">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Faculty Monitored</p>
                        <h2 class="stat-card-value"><%= faculty.length %></h2>
                        <p class="stat-card-sublabel">Active in system</p>
                    </div>
                </div>
            </div>

            <div class="content-card">
                <div class="card-header">
                    <h3 class="card-title">Presence Detection History</h3>
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        <select class="modal-select" id="facultyFilter" style="padding:0.375rem 0.75rem;font-size:0.8125rem;">
                            <option value="all">All Faculty</option>
                            <% faculty.forEach(f => { %>
                            <option value="<%= f.name %>"><%= f.name %></option>
                            <% }); %>
                        </select>
                        <select class="modal-select" id="eventFilter" style="padding:0.375rem 0.75rem;font-size:0.8125rem;">
                            <option value="all">All Events</option>
                            <option value="entered">Entries Only</option>
                            <option value="exited">Exits Only</option>
                        </select>
                    </div>
                </div>
                <div class="card-body" style="padding:0;">
                    <table class="data-table" id="monitoringTable">
                        <thead>
                            <tr>
                                <th>Event</th>
                                <th>Faculty</th>
                                <th>Location</th>
                                <th>Timestamp</th>
                                <th>Duration</th>
                                <th>Method</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% presenceLogs.forEach(log => { %>
                            <tr data-event="<%= log.status %>" data-faculty="<%= log.facultyName %>">
                                <td>
                                    <div class="presence-event-cell">
                                        <span class="presence-row-icon <%= log.status %>" style="width:28px;height:28px;border-radius:6px;display:inline-flex;align-items:center;justify-content:center;">
                                            <% if (log.status === 'entered') { %>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                                            <% } else { %>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                            <% } %>
                                        </span>
                                        <span><%= log.status === 'entered' ? 'Entered' : 'Exited' %></span>
                                    </div>
                                </td>
                                <td><%= log.facultyName %></td>
                                <td><%= log.location %></td>
                                <td><%= log.timestamp %></td>
                                <td><%= log.duration || '—' %></td>
                                <td><span class="table-badge confirmed">BLE SmartTag</span></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <div class="pagination-bar">
                    <button class="btn-page" id="btnPrev">&#8592; Prev</button>
                    <span class="page-info" id="pageInfo"></span>
                    <button class="btn-page" id="btnNext">Next &#8594;</button>
                </div>
            </div>

        </div>
    </main>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
const ROWS_PER_PAGE = 7;
let currentPage = 1;

function getVisibleRows() {
    const faculty = document.getElementById('facultyFilter').value;
    const event = document.getElementById('eventFilter').value;
    return Array.from(document.querySelectorAll('#monitoringTable tbody tr')).filter(row => {
        const matchFaculty = faculty === 'all' || row.dataset.faculty === faculty;
        const matchEvent = event === 'all' || row.dataset.event === event;
        return matchFaculty && matchEvent;
    });
}

function renderPage() {
    const rows = getVisibleRows();
    const totalPages = Math.max(1, Math.ceil(rows.length / ROWS_PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;
    document.querySelectorAll('#monitoringTable tbody tr').forEach(r => r.style.display = 'none');
    rows.slice((currentPage - 1) * ROWS_PER_PAGE, currentPage * ROWS_PER_PAGE).forEach(r => r.style.display = '');
    document.getElementById('pageInfo').textContent = `Page ${currentPage} of ${totalPages}`;
    document.getElementById('btnPrev').disabled = currentPage === 1;
    document.getElementById('btnNext').disabled = currentPage === totalPages;
}

function applyFilters() { currentPage = 1; renderPage(); }

function showToast(type, title, message) {
    const c = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.innerHTML = `<div class="toast-content"><p class="toast-title">${title}</p><p class="toast-message">${message}</p></div>`;
    c.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 4000);
}

document.getElementById('facultyFilter').addEventListener('change', applyFilters);
document.getElementById('eventFilter').addEventListener('change', applyFilters);
document.getElementById('btnPrev').addEventListener('click', () => { currentPage--; renderPage(); });
document.getElementById('btnNext').addEventListener('click', () => { currentPage++; renderPage(); });
document.getElementById('btnExportLogs').addEventListener('click', () => showToast('success', 'Exported', 'Presence logs exported successfully.'));

renderPage();
</script>
