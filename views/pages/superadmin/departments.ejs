<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
.dept-badge{display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .6rem;border-radius:999px;font-size:.65rem;font-weight:700}
.dept-badge.ble-active {background:rgba(22,163,74,.12);color:#15803d}
.dept-badge.ble-pending{background:rgba(234,179,8,.12);color:#92400e}
.dept-dot{width:5px;height:5px;border-radius:50%}
.dept-dot.g{background:#16a34a;animation:blink 1.5s infinite}
.dept-dot.y{background:#d97706}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;z-index:1000;opacity:0;visibility:hidden;transition:all .3s ease;padding:1rem}
.modal-overlay.show{opacity:1;visibility:visible}
.modal-content{background:#fff;border-radius:var(--radius-lg);box-shadow:0 25px 70px rgba(0,0,0,.35);max-width:540px;width:100%;transform:scale(.9);transition:transform .3s cubic-bezier(.34,1.56,.64,1)}
.modal-overlay.show .modal-content{transform:scale(1)}
.modal-header{display:flex;justify-content:space-between;align-items:center;padding:1.25rem 1.5rem;border-bottom:1px solid var(--gray-200)}
.modal-title{font-size:1.125rem;font-weight:700;color:var(--gray-900);margin:0}
.modal-close{width:32px;height:32px;border:none;background:transparent;color:var(--gray-500);cursor:pointer;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;transition:all .2s}
.modal-close:hover{background:var(--gray-100);color:var(--gray-900)}
.modal-body{padding:1.5rem;display:flex;flex-direction:column;gap:1rem}
.modal-footer{display:flex;justify-content:flex-end;gap:.75rem;padding:1rem 1.5rem;border-top:1px solid var(--gray-200);background:var(--gray-50)}
.form-field{display:flex;flex-direction:column;gap:.375rem}
.form-field label{font-size:.8125rem;font-weight:600;color:var(--gray-700)}
.form-field input,.form-field select{padding:.625rem .875rem;border:1.5px solid var(--gray-300);border-radius:var(--radius-md);font-size:.875rem;color:var(--gray-900);background:#fff;font-family:var(--font-body);transition:border-color .2s;width:100%;box-sizing:border-box}
.form-field input:focus,.form-field select:focus{outline:none;border-color:var(--primary-blue);box-shadow:0 0 0 3px rgba(10,61,98,.08)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.delete-confirm{background:#fef2f2;border:1px solid #fecaca;border-radius:var(--radius-md);padding:1rem;font-size:.875rem;color:#991b1b;line-height:1.5}
</style>

<div class="instructor-layout">
  <%- include('../../partials/superadmin-sidebar', { activePage: 'departments' }) %>
  <main class="instructor-main">
    <div class="main-container">

      <div class="page-header">
        <div>
          <h1 class="page-title">Departments</h1>
          <p class="page-subtitle">All CSPC colleges registered in FaciTrack</p>
        </div>
        <div class="header-actions">
          <button class="btn-header-action primary" id="btnAddDept">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Department
          </button>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats-overview">
        <div class="stat-card-large confirmed">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">Total Departments</p>
            <h2 class="stat-card-value"><%= deptData.length %></h2>
            <p class="stat-card-sublabel">CSPC colleges</p>
          </div>
        </div>
        <div class="stat-card-large workload">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 6s4-2 11-2 11 2 11 2v12s-4 2-11 2S1 18 1 18V6z"/><circle cx="12" cy="12" r="3"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">BLE Deployed</p>
            <h2 class="stat-card-value"><%= deptData.filter(d=>d.bleDeployed).length %></h2>
            <p class="stat-card-sublabel">Monitoring active</p>
          </div>
        </div>
        <div class="stat-card-large presence">
          <div class="stat-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div>
          <div class="stat-card-content">
            <p class="stat-card-label">Total Faculty</p>
            <h2 class="stat-card-value"><%= deptData.reduce((s,d)=>s+d.facultyCount,0) %></h2>
            <p class="stat-card-sublabel">Across all departments</p>
          </div>
        </div>
      </div>

      <div class="content-card">
        <div class="card-header">
          <h3 class="card-title">All Departments (<span id="deptCount"><%= deptData.length %></span>)</h3>
          <input type="text" id="deptSearch" placeholder="Search..." oninput="filterDepts()" style="padding:.375rem .75rem;border:1.5px solid var(--gray-200);border-radius:var(--radius-md);font-size:.8125rem;width:180px;font-family:var(--font-body)">
        </div>
        <div class="card-body" style="padding:0">
          <div style="overflow-x:auto">
            <table class="data-table" id="deptTable">
              <thead>
                <tr>
                  <th>#</th>
                  <th>College</th>
                  <th>Building</th>
                  <th>Dean</th>
                  <th>Faculty</th>
                  <th>Rooms</th>
                  <th>BLE Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="deptBody">
                <% deptData.forEach((d,i) => { %>
                <tr data-name="<%= d.name.toLowerCase() %>">
                  <td style="color:var(--gray-400);font-size:.8125rem"><%= i+1 %></td>
                  <td style="font-weight:600"><%= d.name %></td>
                  <td style="font-size:.8125rem;color:var(--gray-600)"><%= d.building %></td>
                  <td style="font-size:.8125rem;color:var(--gray-700)"><%= d.dean %></td>
                  <td style="text-align:center"><%= d.facultyCount %></td>
                  <td style="text-align:center"><%= d.roomCount %></td>
                  <td>
                    <span class="dept-badge <%= d.bleDeployed?'ble-active':'ble-pending' %>">
                      <span class="dept-dot <%= d.bleDeployed?'g':'y' %>"></span>
                      <%= d.bleStatusLabel || (d.bleDeployed?'Active':'Not Deployed') %>
                    </span>
                  </td>
                  <td>
                    <div style="display:flex;gap:.375rem">
                      <button class="btn-icon-action approve" title="Edit"
                        data-id="<%= d.id %>"
                        data-name="<%= d.name %>"
                        data-building="<%= d.building %>"
                        data-dean="<%= d.dean %>"
                        data-faculty="<%= d.facultyCount %>"
                        data-rooms="<%= d.roomCount %>"
                        data-ble="<%= d.bleDeployed %>"
                        data-status="<%= d.status %>"
                        onclick="openEditFromBtn(this)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      </button>
                      <button class="btn-icon-action decline" title="Delete"
                        data-name="<%= d.name %>"
                        onclick="openDeleteFromBtn(this)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                      </button>
                    </div>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>

<!-- Add/Edit Department Modal -->
<div class="modal-overlay" id="deptModal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title" id="deptModalTitle">Add Department</h3>
      <button class="modal-close" onclick="closeDeptModal()">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <div class="form-field">
        <label>Department Name <span style="color:#e53e3e">*</span></label>
        <input type="text" id="dName" placeholder="College of Computer Studies">
      </div>
      <div class="form-row">
        <div class="form-field">
          <label>Building</label>
          <input type="text" id="dBuilding" placeholder="CCS Building">
        </div>
        <div class="form-field">
          <label>Dean Assigned</label>
          <input type="text" id="dDean" placeholder="Dr. Lourdes Reyes">
        </div>
      </div>
      <div class="form-row">
        <div class="form-field">
          <label>Status</label>
          <select id="dStatus">
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
          </select>
        </div>
        <div class="form-field">
          <label>BLE Monitoring</label>
          <select id="dBle">
            <option value="false">Not Deployed</option>
            <option value="true">Deployed / Active</option>
          </select>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-modal btn-cancel" onclick="closeDeptModal()">Cancel</button>
      <button class="btn-modal btn-confirm" style="background:linear-gradient(135deg,var(--primary-blue),#1e88e5);color:#fff" onclick="saveDept()">Save Department</button>
    </div>
  </div>
</div>

<!-- Delete Department Modal -->
<div class="modal-overlay" id="deleteDeptModal">
  <div class="modal-content" style="max-width:420px">
    <div class="modal-header">
      <h3 class="modal-title">Delete Department</h3>
      <button class="modal-close" onclick="closeDeleteDeptModal()">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <div class="delete-confirm">
        <strong>Delete "<span id="delDeptName"></span>"?</strong><br><br>
        This will remove the department and all associated room assignments. Faculty and Dean accounts linked to this department will need to be reassigned. This action cannot be undone.
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-modal btn-cancel" onclick="closeDeleteDeptModal()">Cancel</button>
      <button class="btn-modal btn-confirm" onclick="confirmDeleteDept()">Delete Department</button>
    </div>
  </div>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
(function(){
  var editingDeptId = null, deletingDeptId = null, deletingName = null;

  function showToast(type,title,msg){
    var c=document.getElementById('toastContainer'),t=document.createElement('div');
    t.className='toast '+type;
    t.innerHTML='<div class="toast-content"><p class="toast-title">'+title+'</p><p class="toast-message">'+msg+'</p></div>';
    c.appendChild(t);
    setTimeout(function(){t.style.opacity='0';setTimeout(function(){t.remove();},300);},4000);
  }

  window.filterDepts=function(){
    var q=document.getElementById('deptSearch').value.toLowerCase();
    var rows=document.querySelectorAll('#deptBody tr');
    var count=0;
    rows.forEach(function(r){
      var show=!q||r.dataset.name.includes(q);
      r.style.display=show?'':'none';
      if(show) count++;
    });
    document.getElementById('deptCount').textContent=count;
  };

  // Add
  document.getElementById('btnAddDept').addEventListener('click',function(){
    editingDeptId=null;
    document.getElementById('deptModalTitle').textContent='Add Department';
    ['dName','dBuilding','dDean'].forEach(function(id){document.getElementById(id).value='';});
    document.getElementById('dStatus').value='active';
    document.getElementById('dBle').value='false';
    document.getElementById('deptModal').classList.add('show');
  });

  // Edit via data attributes
  window.openEditFromBtn=function(btn){
    editingDeptId=Number(btn.dataset.id);
    document.getElementById('deptModalTitle').textContent='Edit Department';
    document.getElementById('dName').value=btn.dataset.name;
    document.getElementById('dBuilding').value=btn.dataset.building;
    document.getElementById('dDean').value=btn.dataset.dean;
    document.getElementById('dStatus').value=btn.dataset.status||'active';
    document.getElementById('dBle').value=btn.dataset.ble==='true'?'true':'false';
    document.getElementById('deptModal').classList.add('show');
  };

  window.closeDeptModal=function(){
    editingDeptId=null;
    document.getElementById('deptModal').classList.remove('show');
  };

  window.saveDept=function(){
    var name=document.getElementById('dName').value.trim();
    if(!name){showToast('error','Required','Department name is required.');return;}
    var payload = {
      name: name,
      shortName: '',
      building: document.getElementById('dBuilding').value.trim(),
      dean: document.getElementById('dDean').value.trim(),
      status: document.getElementById('dStatus').value,
      bleDeployed: document.getElementById('dBle').value === 'true'
    };
    var isEdit = editingDeptId !== null;
    fetch(isEdit ? '/superadmin/departments/' + editingDeptId : '/superadmin/departments', {
      method: isEdit ? 'PATCH' : 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
      .then(function(res){ return res.json().then(function(data){ return { ok: res.ok, data: data }; }); })
      .then(function(result){
        if(!result.ok) throw new Error(result.data && result.data.error ? result.data.error : 'Failed to save department.');
        showToast('success', isEdit ? 'Department Updated' : 'Department Added', '"' + name + '" has been ' + (isEdit ? 'updated' : 'added') + '.');
        closeDeptModal();
        window.location.reload();
      })
      .catch(function(err){
        showToast('error', 'Save failed', err.message || 'Please try again.');
      });
  };

  // Delete via data attributes
  window.openDeleteFromBtn=function(btn){
    deletingName=btn.dataset.name;
    var editBtn = btn.parentElement && btn.parentElement.querySelector('.btn-icon-action.approve');
    deletingDeptId = editBtn ? Number(editBtn.dataset.id) : null;
    document.getElementById('delDeptName').textContent=deletingName;
    document.getElementById('deleteDeptModal').classList.add('show');
  };

  window.closeDeleteDeptModal=function(){
    deletingName=null;
    deletingDeptId=null;
    document.getElementById('deleteDeptModal').classList.remove('show');
  };

  window.confirmDeleteDept=function(){
    if(!deletingDeptId){
      showToast('error','Delete failed','Department id is missing.');
      return;
    }
    fetch('/superadmin/departments/' + deletingDeptId, { method: 'DELETE' })
      .then(function(res){ return res.json().then(function(data){ return { ok: res.ok, data: data }; }); })
      .then(function(result){
        if(!result.ok) throw new Error(result.data && result.data.error ? result.data.error : 'Failed to delete department.');
        showToast('success','Deleted','"'+deletingName+'" has been removed.');
        closeDeleteDeptModal();
        window.location.reload();
      })
      .catch(function(err){
        showToast('error','Delete failed', err.message || 'Please try again.');
      });
  };

  // Close on overlay click
  ['deptModal','deleteDeptModal'].forEach(function(id){
    document.getElementById(id).addEventListener('click',function(e){if(e.target===this) window['close'+(id==='deptModal'?'Dept':'DeleteDept')+'Modal']();});
  });
}());
</script>
