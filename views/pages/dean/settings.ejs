<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
.settings-grid { display:grid; grid-template-columns:360px 1fr; gap:1.5rem; align-items:start; }
@media(max-width:1100px){ .settings-grid { grid-template-columns:1fr; } }
.profile-card-top { display:flex; flex-direction:column; align-items:center; padding:2rem 1.5rem 1.5rem; border-bottom:1px solid var(--gray-100); text-align:center; }
.settings-avatar-wrap { position:relative; width:88px; height:88px; margin-bottom:1rem; }
.settings-avatar-wrap .profile-avatar-mini { width:88px; height:88px; font-size:1.75rem; }
.settings-avatar-wrap .avatar-upload-overlay { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; background:rgba(0,0,0,.45); border-radius:50%; opacity:0; transition:opacity .2s; cursor:pointer; color:#fff; }
.settings-avatar-wrap:hover .avatar-upload-overlay { opacity:1; }
.settings-name  { font-size:1.0625rem; font-weight:700; color:var(--gray-900); margin:0 0 .2rem; }
.settings-email { font-size:.8125rem; color:var(--gray-500); margin:0 0 .25rem; }
.settings-dept  { font-size:.75rem; color:var(--primary-blue); font-weight:600; margin:0; }
.settings-right { display:flex; flex-direction:column; gap:1.5rem; }
.settings-toggle-row { display:flex; align-items:center; justify-content:space-between; gap:1rem; padding:.875rem; border:1px solid var(--gray-200); border-radius:var(--radius-md); background:#fff; transition:border-color .2s,background .2s; }
.settings-toggle-row:hover { border-color:var(--primary-blue); background:rgba(10,61,98,.02); }
.toggle-label { font-size:.875rem; font-weight:600; color:var(--gray-900); margin:0 0 .125rem; }
.toggle-desc  { font-size:.75rem; color:var(--gray-500); margin:0; line-height:1.4; }
.toggle-switch { position:relative; width:44px; height:24px; flex-shrink:0; }
.toggle-switch input { opacity:0; width:0; height:0; position:absolute; }
.toggle-slider { position:absolute; cursor:pointer; inset:0; background:var(--gray-300); border-radius:24px; transition:.3s; }
.toggle-slider:before { content:''; position:absolute; width:18px; height:18px; left:3px; bottom:3px; background:#fff; border-radius:50%; transition:.3s; box-shadow:0 1px 4px rgba(0,0,0,.2); }
input:checked + .toggle-slider { background:var(--primary-blue); }
input:checked + .toggle-slider:before { transform:translateX(20px); }
</style>

<div class="instructor-layout">
  <%- include('../../partials/dean-sidebar', { activePage: 'settings' }) %>
  <main class="instructor-main">
    <div class="main-container">

      <div class="page-header">
        <div>
          <h1 class="page-title">Settings</h1>
          <p class="page-subtitle">Manage your profile and department preferences</p>
        </div>
      </div>

      <div class="settings-grid">

        <!-- LEFT: Profile card -->
        <div style="display:flex;flex-direction:column;gap:1.5rem;">

          <div class="content-card">
            <div class="profile-card-top">
              <div class="settings-avatar-wrap">
                <div class="profile-avatar-mini" id="settingsAvatar">
                  <span class="avatar-initials"><%= dean.name.split(' ').map(n=>n[0]).join('') %></span>
                  <label class="avatar-upload-overlay" title="Change photo">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                    <input type="file" id="settingsAvatarInput" accept="image/*" style="display:none;">
                  </label>
                </div>
              </div>
              <p class="settings-name" id="displayName"><%= dean.name %></p>
              <p class="settings-email" id="displayEmail"><%= dean.email %></p>
              <p class="settings-dept"><%= dean.department %></p>
            </div>
            <div class="card-body">
              <div class="form-group">
                <label class="modal-label">Full Name</label>
                <input type="text" class="modal-input" id="inputName" value="<%= dean.name %>">
              </div>
              <div class="form-group">
                <label class="modal-label">Email Address</label>
                <input type="email" class="modal-input" id="inputEmail" value="<%= dean.email %>">
              </div>
              <div class="form-group">
                <label class="modal-label">Phone Number</label>
                <input type="tel" class="modal-input" id="inputPhone" placeholder="e.g. +63 912 345 6789">
              </div>
              <button class="btn-save-settings" id="btnSaveProfile">Save Changes</button>
            </div>
          </div>

          <!-- Security -->
          <div class="content-card">
            <div class="card-header"><h3 class="card-title">Security</h3></div>
            <div class="card-body">
              <div class="form-group">
                <label class="modal-label">Current Password</label>
                <input type="password" class="modal-input" id="inputCurrentPw" placeholder="Enter current password">
              </div>
              <div class="form-group">
                <label class="modal-label">New Password</label>
                <input type="password" class="modal-input" id="inputNewPw" placeholder="At least 8 characters">
              </div>
              <div class="form-group">
                <label class="modal-label">Confirm New Password</label>
                <input type="password" class="modal-input" id="inputConfirmPw" placeholder="Repeat new password">
              </div>
              <button class="btn-save-settings" id="btnChangePassword">Update Password</button>
            </div>
          </div>

        </div>

        <!-- RIGHT: Preferences -->
        <div class="settings-right">

          <!-- Department Preferences -->
          <div class="content-card">
            <div class="card-header"><h3 class="card-title">Department Preferences</h3></div>
            <div class="card-body">
              <div class="settings-toggle-list">
                <div class="settings-toggle-row">
                  <div>
                    <p class="toggle-label">Faculty Presence Alerts</p>
                    <p class="toggle-desc">Get notified when a faculty member is absent during scheduled hours</p>
                  </div>
                  <label class="toggle-switch"><input type="checkbox" checked><span class="toggle-slider"></span></label>
                </div>
                <div class="settings-toggle-row">
                  <div>
                    <p class="toggle-label">New Appointment Notifications</p>
                    <p class="toggle-desc">Receive alerts when students book consultations with faculty</p>
                  </div>
                  <label class="toggle-switch"><input type="checkbox" checked><span class="toggle-slider"></span></label>
                </div>
                <div class="settings-toggle-row">
                  <div>
                    <p class="toggle-label">Weekly Workload Summary</p>
                    <p class="toggle-desc">Receive a weekly digest of faculty consultation hours</p>
                  </div>
                  <label class="toggle-switch"><input type="checkbox" checked><span class="toggle-slider"></span></label>
                </div>
                <div class="settings-toggle-row">
                  <div>
                    <p class="toggle-label">BLE Monitoring Alerts</p>
                    <p class="toggle-desc">Real-time alerts for BLE detection anomalies in the department</p>
                  </div>
                  <label class="toggle-switch"><input type="checkbox"><span class="toggle-slider"></span></label>
                </div>
              </div>
              <button class="btn-save-settings" id="btnSavePrefs" style="margin-top:1.25rem;">Save Preferences</button>
            </div>
          </div>

          <!-- Report Settings -->
          <div class="content-card">
            <div class="card-header"><h3 class="card-title">Report Settings</h3></div>
            <div class="card-body">
              <div class="form-group">
                <label class="modal-label">Default Report Period</label>
                <select class="modal-input" id="defaultPeriod">
                  <option value="week">This Week</option>
                  <option value="month" selected>This Month</option>
                  <option value="all">All Time</option>
                </select>
              </div>
              <div class="form-group">
                <label class="modal-label">Report Header — College Name</label>
                <input type="text" class="modal-input" id="reportCollege" value="<%= dean.department %>">
              </div>
              <div class="form-group">
                <label class="modal-label">Dean's Name (for report signature)</label>
                <input type="text" class="modal-input" id="reportDeanName" value="<%= dean.name %>">
              </div>
              <button class="btn-save-settings" id="btnSaveReport">Save Report Settings</button>
            </div>
          </div>

          <!-- Notification Preferences -->
          <div class="content-card">
            <div class="card-header"><h3 class="card-title">Notification Preferences</h3></div>
            <div class="card-body">
              <div class="settings-toggle-list">
                <div class="settings-toggle-row">
                  <div>
                    <p class="toggle-label">Email Notifications</p>
                    <p class="toggle-desc">Receive alerts via email for important events</p>
                  </div>
                  <label class="toggle-switch"><input type="checkbox" checked><span class="toggle-slider"></span></label>
                </div>
                <div class="settings-toggle-row">
                  <div>
                    <p class="toggle-label">In-App Notifications</p>
                    <p class="toggle-desc">Show notification badges inside the FaciTrack dashboard</p>
                  </div>
                  <label class="toggle-switch"><input type="checkbox" checked><span class="toggle-slider"></span></label>
                </div>
                <div class="settings-toggle-row">
                  <div>
                    <p class="toggle-label">Faculty Status Change Alerts</p>
                    <p class="toggle-desc">Notify when a faculty member changes their availability status</p>
                  </div>
                  <label class="toggle-switch"><input type="checkbox"><span class="toggle-slider"></span></label>
                </div>
              </div>
              <button class="btn-save-settings" id="btnSaveNotifs" style="margin-top:1.25rem;">Save Notifications</button>
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
(function(){
  function showToast(type, title, msg){
    var c=document.getElementById('toastContainer'), t=document.createElement('div');
    t.className='toast '+type;
    t.innerHTML='<div class="toast-content"><p class="toast-title">'+title+'</p><p class="toast-message">'+msg+'</p></div>';
    c.appendChild(t);
    setTimeout(function(){ t.style.opacity='0'; setTimeout(function(){ t.remove(); },300); },4000);
  }

  document.getElementById('btnSaveProfile').addEventListener('click',function(){
    var name=document.getElementById('inputName').value.trim();
    var email=document.getElementById('inputEmail').value.trim();
    if(!name||!email){ showToast('error','Missing Fields','Please fill in your name and email.'); return; }
    document.getElementById('displayName').textContent=name;
    document.getElementById('displayEmail').textContent=email;
    showToast('success','Saved','Profile information updated.');
  });

  document.getElementById('btnChangePassword').addEventListener('click',function(){
    var cur=document.getElementById('inputCurrentPw').value;
    var nw=document.getElementById('inputNewPw').value;
    var conf=document.getElementById('inputConfirmPw').value;
    if(!cur||!nw||!conf){ showToast('error','Missing Fields','Please fill in all password fields.'); return; }
    if(nw.length<8){ showToast('error','Too Short','New password must be at least 8 characters.'); return; }
    if(nw!==conf){ showToast('error','Mismatch','New passwords do not match.'); return; }
    ['inputCurrentPw','inputNewPw','inputConfirmPw'].forEach(function(id){ document.getElementById(id).value=''; });
    showToast('success','Updated','Password changed successfully.');
  });

  document.getElementById('btnSavePrefs').addEventListener('click',function(){ showToast('success','Saved','Department preferences updated.'); });
  document.getElementById('btnSaveReport').addEventListener('click',function(){ showToast('success','Saved','Report settings updated.'); });
  document.getElementById('btnSaveNotifs').addEventListener('click',function(){ showToast('success','Saved','Notification preferences updated.'); });

  // Avatar upload
  var inp=document.getElementById('settingsAvatarInput');
  var av=document.getElementById('settingsAvatar');
  if(inp&&av){
    inp.addEventListener('change',function(){
      var file=this.files[0];
      if(!file||!file.type.startsWith('image/')) return;
      var reader=new FileReader();
      reader.onload=function(e){
        var init=av.querySelector('.avatar-initials');
        var existing=av.querySelector('.avatar-img');
        if(init) init.remove();
        if(existing) existing.remove();
        var img=document.createElement('img');
        img.src=e.target.result; img.className='avatar-img';
        av.insertBefore(img, av.querySelector('.avatar-upload-overlay')||null);
        localStorage.setItem('deanProfilePhoto',e.target.result);
      };
      reader.readAsDataURL(file);
    });
    var saved=localStorage.getItem('deanProfilePhoto');
    if(saved){
      var init=av.querySelector('.avatar-initials');
      if(init) init.remove();
      var img=document.createElement('img');
      img.src=saved; img.className='avatar-img';
      av.insertBefore(img, av.querySelector('.avatar-upload-overlay')||null);
    }
  }
}());
</script>
