<%- include('../../partials/header') %>
<link rel="stylesheet" href="/css/instructor/dashboard.css?v=<%= Date.now() %>">
<style>
    html, body { overflow: hidden !important; height: 100vh !important; }
    body { display: flex; flex-direction: column; }
    main { flex: 1; min-height: 0; display: flex; flex-direction: column; }
</style>

<div class="instructor-layout">
    <%- include('../../partials/dean-sidebar', { activePage: 'appointments' }) %>

    <main class="instructor-main">
        <div class="main-container">

            <div class="page-header">
                <div>
                    <h1 class="page-title">Appointments</h1>
                    <p class="page-subtitle">All consultation appointments across all faculty members</p>
                </div>
                <div class="header-actions">
                    <button class="btn-header-action" id="btnExportAppointments">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        Export
                    </button>
                </div>
            </div>

            <!-- Stats -->
            <div class="stats-overview">
                <div class="stat-card-large pending">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Pending</p>
                        <h2 class="stat-card-value"><%= allAppointments.filter(a => a.status === 'pending').length %></h2>
                        <p class="stat-card-sublabel">Awaiting response</p>
                    </div>
                </div>
                <div class="stat-card-large confirmed">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Confirmed</p>
                        <h2 class="stat-card-value"><%= allAppointments.filter(a => a.status === 'confirmed').length %></h2>
                        <p class="stat-card-sublabel">Scheduled</p>
                    </div>
                </div>
                <div class="stat-card-large presence">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Declined</p>
                        <h2 class="stat-card-value"><%= allAppointments.filter(a => a.status === 'declined').length %></h2>
                        <p class="stat-card-sublabel">Not approved</p>
                    </div>
                </div>
                <div class="stat-card-large workload">
                    <div class="stat-card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                    <div class="stat-card-content">
                        <p class="stat-card-label">Total</p>
                        <h2 class="stat-card-value"><%= allAppointments.length %></h2>
                        <p class="stat-card-sublabel">All appointments</p>
                    </div>
                </div>
            </div>

            <!-- Appointments Table -->
            <div class="content-card">
                <div class="card-header">
                    <h3 class="card-title">All Appointments</h3>
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        <select class="modal-select" id="instructorFilter" style="padding:0.375rem 0.75rem;font-size:0.8125rem;">
                            <option value="all">All Faculty</option>
                            <% faculty.forEach(f => { %>
                            <option value="<%= f.name %>"><%= f.name %></option>
                            <% }); %>
                        </select>
                        <select class="modal-select" id="statusFilter" style="padding:0.375rem 0.75rem;font-size:0.8125rem;">
                            <option value="all">All Status</option>
                            <option value="pending">Pending</option>
                            <option value="confirmed">Confirmed</option>
                            <option value="declined">Declined</option>
                        </select>
                    </div>
                </div>
                <div class="card-body" style="padding:0;">
                    <table class="data-table" id="appointmentsTable">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Faculty</th>
                                <th>Date & Time</th>
                                <th>Topic</th>
                                <th>Duration</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% allAppointments.forEach(apt => { %>
                            <tr data-status="<%= apt.status %>" data-instructor="<%= apt.instructorName %>">
                                <td>
                                    <div style="display:flex;align-items:center;gap:0.75rem;">
                                        <div class="apt-avatar-xs"><%= apt.studentName.split(' ').map(n => n[0]).join('') %></div>
                                        <div>
                                            <p style="font-weight:600;font-size:0.875rem;color:var(--gray-900);margin:0;"><%= apt.studentName %></p>
                                            <p style="font-size:0.75rem;color:var(--gray-500);margin:0;"><%= apt.studentId %></p>
                                        </div>
                                    </div>
                                </td>
                                <td><%= apt.instructorName %></td>
                                <td><%= apt.date %> • <%= apt.time %></td>
                                <td style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="<%= apt.topic %>"><%= apt.topic %></td>
                                <td><%= apt.duration %></td>
                                <td><span class="table-badge <%= apt.status %>"><%= apt.status.charAt(0).toUpperCase() + apt.status.slice(1) %></span></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
                <div class="pagination-bar">
                    <button class="btn-page" id="btnPrev">&#8592; Prev</button>
                    <span class="page-info" id="pageInfo"></span>
                    <button class="btn-page" id="btnNext">Next &#8594;</button>
                </div>
            </div>

        </div>
    </main>
</div>

<div class="toast-container" id="toastContainer"></div>
<%- include('../../partials/footer') %>
<%- include('../../partials/script') %>
<script>
const ROWS_PER_PAGE = 7;
let currentPage = 1;

function getVisibleRows() {
    const instructor = document.getElementById('instructorFilter').value;
    const status = document.getElementById('statusFilter').value;
    return Array.from(document.querySelectorAll('#appointmentsTable tbody tr')).filter(row => {
        const matchInstructor = instructor === 'all' || row.dataset.instructor === instructor;
        const matchStatus = status === 'all' || row.dataset.status === status;
        return matchInstructor && matchStatus;
    });
}

function renderPage() {
    const rows = getVisibleRows();
    const totalPages = Math.max(1, Math.ceil(rows.length / ROWS_PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;

    document.querySelectorAll('#appointmentsTable tbody tr').forEach(r => r.style.display = 'none');
    rows.slice((currentPage - 1) * ROWS_PER_PAGE, currentPage * ROWS_PER_PAGE).forEach(r => r.style.display = '');

    document.getElementById('pageInfo').textContent = `Page ${currentPage} of ${totalPages}`;
    document.getElementById('btnPrev').disabled = currentPage === 1;
    document.getElementById('btnNext').disabled = currentPage === totalPages;
}

function applyFilters() { currentPage = 1; renderPage(); }

function showToast(type, title, message) {
    const c = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.innerHTML = `<div class="toast-content"><p class="toast-title">${title}</p><p class="toast-message">${message}</p></div>`;
    c.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 4000);
}

document.getElementById('instructorFilter').addEventListener('change', applyFilters);
document.getElementById('statusFilter').addEventListener('change', applyFilters);
document.getElementById('btnPrev').addEventListener('click', () => { currentPage--; renderPage(); });
document.getElementById('btnNext').addEventListener('click', () => { currentPage++; renderPage(); });
document.getElementById('btnExportAppointments').addEventListener('click', () => showToast('success', 'Exported', 'Appointments data exported successfully.'));

renderPage();
</script>
