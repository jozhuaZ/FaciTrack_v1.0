<aside class="instructor-sidebar">
    <div class="sidebar-header">
        <div class="instructor-profile-mini">
            <div class="profile-avatar-mini" id="sidebarAvatar">
                <% if (instructor.profilePhoto) { %>
                    <img src="<%= instructor.profilePhoto %>" alt="<%= instructor.name %>" class="avatar-img">
                <% } else { %>
                    <span class="avatar-initials"><%= instructor.name.split(' ').map(n => n[0]).join('') %></span>
                <% } %>
                <label class="avatar-upload-overlay" title="Change photo">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                    <input type="file" id="avatarInput" accept="image/*" style="display:none;">
                </label>
            </div>
            <div class="profile-info-mini">
                <h3 class="profile-name-mini"><%= instructor.name %></h3>
                <p class="profile-role-mini"><%= instructor.position %></p>
            </div>
        </div>
        <div class="ble-status-mini">
            <span class="ble-indicator-mini <%= instructor.bleStatus %>">
                <span class="ble-pulse-mini"></span>
                <span class="ble-dot-mini"></span>
            </span>
            <span class="ble-text-mini"><%= instructor.bleStatus === 'in-room' ? 'In Room' : 'Out of Room' %></span>
        </div>
        <!-- Mobile hamburger toggle -->
        <button class="sidebar-mobile-toggle" id="sidebarToggle" aria-label="Toggle navigation" aria-expanded="false">
            <svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            <svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
    </div>

    <nav class="sidebar-nav">
        <a href="/instructor/dashboard" class="nav-item <%= activePage === 'dashboard' ? 'active' : '' %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect>
                <rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect>
            </svg>
            <span>Dashboard</span>
        </a>
        <a href="/instructor/consultations" class="nav-item <%= activePage === 'consultations' ? 'active' : '' %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            <span>Appointments</span>
            <% if (pendingCount > 0) { %>
            <span class="nav-badge"><%= pendingCount %></span>
            <% } %>
        </a>
        <a href="/instructor/schedule" class="nav-item <%= activePage === 'schedule' ? 'active' : '' %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <span>Schedule</span>
        </a>
        <a href="/instructor/workload" class="nav-item <%= activePage === 'workload' ? 'active' : '' %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="20" x2="18" y2="10"></line>
                <line x1="12" y1="20" x2="12" y2="4"></line>
                <line x1="6" y1="20" x2="6" y2="14"></line>
            </svg>
            <span>Workload</span>
        </a>
        <a href="/instructor/reports" class="nav-item <%= activePage === 'reports' ? 'active' : '' %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line>
            </svg>
            <span>Reports</span>
        </a>
        <a href="/instructor/presence" class="nav-item <%= activePage === 'presence' ? 'active' : '' %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Presence Log</span>
        </a>
        <a href="/instructor/settings" class="nav-item <%= activePage === 'settings' ? 'active' : '' %>">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
            </svg>
            <span>Settings</span>
        </a>
    </nav>

    <div class="sidebar-footer">
        <!-- Notification bell -->
        <% const unreadCount = (typeof notifications !== 'undefined') ? notifications.filter(n => !n.read).length : 0; %>
        <button class="btn-notif-bell" id="btnNotifBell" aria-label="Notifications">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <span>Notifications</span>
            <% if (unreadCount > 0) { %>
            <span class="notif-bell-badge" id="notifBellBadge"><%= unreadCount %></span>
            <% } else { %>
            <span class="notif-bell-badge" id="notifBellBadge" style="display:none">0</span>
            <% } %>
        </button>

        <a href="/instructor/login" class="btn-logout-sidebar">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <polyline points="16 17 21 12 16 7"></polyline>
                <line x1="21" y1="12" x2="9" y2="12"></line>
            </svg>
            <span>Logout</span>
        </a>
    </div>
</aside>

<!-- Notifications Panel (slide-in, available on every instructor page) -->
<div class="notif-backdrop" id="notifBackdrop"></div>
<div class="notif-panel" id="notifPanel" aria-label="Notifications panel">

    <div class="notif-panel-header">
        <div>
            <h3 class="notif-panel-title">Notifications</h3>
            <span class="notif-panel-subtitle" id="notifSubtitle">
                <% const _unreadCount = (typeof notifications !== 'undefined') ? notifications.filter(n=>!n.read).length : 0; %>
                <%= _unreadCount > 0 ? _unreadCount + ' unread' : 'All caught up' %>
            </span>
        </div>
        <div style="display:flex;align-items:center;gap:.4rem">
            <button class="notif-mark-all" id="notifMarkAll">Mark all read</button>
            <button class="notif-clear-read" id="notifClearRead" title="Remove all read notifications">Clear read</button>
            <button class="notif-panel-close" id="notifPanelClose" aria-label="Close">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
    </div>

    <!-- Filter tabs -->
    <div class="notif-filter-bar">
        <button class="notif-filter-btn active" data-filter="all">All</button>
        <button class="notif-filter-btn" data-filter="new-request">Requests</button>
        <button class="notif-filter-btn" data-filter="cancellation">Cancels</button>
        <button class="notif-filter-btn" data-filter="reminder">Reminders</button>
        <button class="notif-filter-btn" data-filter="alert">Alerts</button>
    </div>

    <div class="notif-panel-body" id="notifPanelBody">
        <%
        const _allNotifs = (typeof notifications !== 'undefined') ? notifications : [];
        const _unread    = _allNotifs.filter(n => !n.read);
        const _read      = _allNotifs.filter(n =>  n.read);
        const BATCH      = 10;
        %>

        <% if (_allNotifs.length === 0) { %>
            <div class="notif-panel-empty">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                <p>No notifications yet</p>
            </div>
        <% } else { %>

            <% if (_unread.length > 0) { %>
            <div class="notif-group-label">
                <span>Unread</span>
                <span class="notif-group-count"><%= _unread.length %></span>
            </div>
            <% _unread.forEach(notif => { %>
            <div class="notif-panel-item unread" data-id="<%= notif.id %>" data-type="<%= notif.type %>">
                <div class="notif-panel-icon <%= notif.type %>">
                    <% if (notif.type === 'new-request') { %>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                    <% } else if (notif.type === 'cancellation') { %>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    <% } else if (notif.type === 'reminder') { %>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <% } else { %>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <% } %>
                </div>
                <div class="notif-panel-content">
                    <p class="notif-panel-msg"><%= notif.message %></p>
                    <span class="notif-panel-time"><%= notif.time %></span>
                </div>
                <span class="notif-panel-dot"></span>
            </div>
            <% }); %>
            <% } %>

            <% if (_read.length > 0) { %>
            <div class="notif-group-label">
                <span>Earlier</span>
                <span class="notif-group-count"><%= _read.length %></span>
            </div>
            <% _read.slice(0, BATCH).forEach(notif => { %>
            <div class="notif-panel-item" data-id="<%= notif.id %>" data-type="<%= notif.type %>">
                <div class="notif-panel-icon <%= notif.type %>">
                    <% if (notif.type === 'new-request') { %>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                    <% } else if (notif.type === 'cancellation') { %>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    <% } else if (notif.type === 'reminder') { %>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <% } else { %>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <% } %>
                </div>
                <div class="notif-panel-content">
                    <p class="notif-panel-msg"><%= notif.message %></p>
                    <span class="notif-panel-time"><%= notif.time %></span>
                </div>
            </div>
            <% }); %>
            <% if (_read.length > BATCH) { %>
            <button class="notif-load-more" id="notifLoadMore" data-shown="<%= BATCH %>" data-total="<%= _read.length %>">
                Load more · <%= _read.length - BATCH %> remaining
            </button>
            <% } %>
            <% } %>

        <% } %>
    </div>
</div>

<script>
(function() {
    // ── Avatar upload ──
    const input = document.getElementById('avatarInput');
    const avatar = document.getElementById('sidebarAvatar');
    if (input && avatar) {
        input.addEventListener('change', function() {
            const file = this.files[0];
            if (!file || !file.type.startsWith('image/')) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                const initials = avatar.querySelector('.avatar-initials');
                const existing = avatar.querySelector('.avatar-img');
                if (initials) initials.remove();
                if (existing) existing.remove();
                const img = document.createElement('img');
                img.src = e.target.result;
                img.alt = 'Profile Photo';
                img.className = 'avatar-img';
                avatar.insertBefore(img, avatar.querySelector('.avatar-upload-overlay'));
                localStorage.setItem('instructorProfilePhoto', e.target.result);
            };
            reader.readAsDataURL(file);
        });
        const saved = localStorage.getItem('instructorProfilePhoto');
        if (saved) {
            const initials = avatar.querySelector('.avatar-initials');
            const existing = avatar.querySelector('.avatar-img');
            if (initials) initials.remove();
            if (existing) existing.remove();
            const img = document.createElement('img');
            img.src = saved;
            img.alt = 'Profile Photo';
            img.className = 'avatar-img';
            avatar.insertBefore(img, avatar.querySelector('.avatar-upload-overlay'));
        }
    }

    // ── Notifications panel ──
    const bell     = document.getElementById('btnNotifBell');
    const panel    = document.getElementById('notifPanel');
    const backdrop = document.getElementById('notifBackdrop');
    const closeBtn = document.getElementById('notifPanelClose');
    const markAll  = document.getElementById('notifMarkAll');
    const clearRead= document.getElementById('notifClearRead');
    const badge    = document.getElementById('notifBellBadge');
    const body     = document.getElementById('notifPanelBody');
    const subtitle = document.getElementById('notifSubtitle');

    function updateBadge() {
        if (!badge) return;
        const count = document.querySelectorAll('.notif-panel-item.unread').length;
        if (count === 0) { badge.style.display = 'none'; return; }
        badge.style.display = 'inline-flex';
        badge.textContent = count > 9 ? '9+' : count;
    }

    function updateSubtitle() {
        if (!subtitle) return;
        const count = document.querySelectorAll('.notif-panel-item.unread').length;
        subtitle.textContent = count > 0 ? count + ' unread' : 'All caught up';
    }

    function openPanel() {
        panel.classList.add('open');
        backdrop.classList.add('open');
        document.body.style.overflow = 'hidden';
        setFilter('all');
    }
    function closePanel() {
        panel.classList.remove('open');
        backdrop.classList.remove('open');
        document.body.style.overflow = '';
    }

    if (bell)     bell.addEventListener('click', openPanel);
    if (closeBtn) closeBtn.addEventListener('click', closePanel);
    if (backdrop) backdrop.addEventListener('click', closePanel);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closePanel(); });

    // Mark all read
    if (markAll) {
        markAll.addEventListener('click', function() {
            document.querySelectorAll('.notif-panel-item.unread').forEach(item => {
                item.classList.remove('unread');
                const dot = item.querySelector('.notif-panel-dot');
                if (dot) dot.remove();
            });
            document.querySelectorAll('.notification-row.unread').forEach(row => {
                row.classList.remove('unread');
                const dot = row.querySelector('.notif-unread-dot');
                if (dot) dot.remove();
            });
            // Hide the "Unread" group label
            if (body) {
                body.querySelectorAll('.notif-group-label').forEach(lbl => {
                    if (lbl.querySelector('span:first-child') &&
                        lbl.querySelector('span:first-child').textContent.trim() === 'Unread') {
                        lbl.style.display = 'none';
                    }
                });
            }
            updateBadge();
            updateSubtitle();
        });
    }

    // Clear all read
    if (clearRead) {
        clearRead.addEventListener('click', function() {
            if (!confirm('Remove all read notifications? This cannot be undone.')) return;
            if (body) {
                body.querySelectorAll('.notif-panel-item:not(.unread)').forEach(item => item.remove());
                body.querySelectorAll('.notif-group-label').forEach(lbl => {
                    const span = lbl.querySelector('span:first-child');
                    if (span && span.textContent.trim() === 'Earlier') lbl.remove();
                });
                const loadMore = document.getElementById('notifLoadMore');
                if (loadMore) loadMore.remove();
                if (!body.querySelector('.notif-panel-item')) {
                    body.innerHTML = '<div class="notif-panel-empty"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg><p>No notifications yet</p></div>';
                }
            }
        });
    }

    // Filter tabs
    function setFilter(type) {
        document.querySelectorAll('.notif-filter-btn').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.filter === type);
        });
        if (!body) return;
        body.querySelectorAll('.notif-panel-item').forEach(item => {
            item.style.display = (type === 'all' || item.dataset.type === type) ? '' : 'none';
        });
        // Hide group labels if no visible items follow them
        body.querySelectorAll('.notif-group-label').forEach(label => {
            let sib = label.nextElementSibling;
            let hasVisible = false;
            while (sib && sib.classList.contains('notif-panel-item')) {
                if (sib.style.display !== 'none') { hasVisible = true; break; }
                sib = sib.nextElementSibling;
            }
            label.style.display = hasVisible ? '' : 'none';
        });
    }

    document.querySelectorAll('.notif-filter-btn').forEach(btn => {
        btn.addEventListener('click', () => setFilter(btn.dataset.filter));
    });

    // Load more
    const loadMoreBtn = document.getElementById('notifLoadMore');
    if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', function() {
            // Prototype: just disable — real app would fetch next batch from server
            this.textContent = 'No more notifications';
            this.disabled = true;
            this.style.opacity = '0.5';
            this.style.cursor = 'default';
        });
    }

    // Init
    updateBadge();
})();
</script>
